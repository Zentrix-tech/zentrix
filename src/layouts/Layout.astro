---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Zentrix Technology — Digital Solutions For Real Growth. Simple. Smart. Effective. We build digital experiences that drive results."
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://zentrix-technology.vercel.app');

const anim = {
  old: {
    name: 'old-exit-curtain',
    duration: '300ms',
    easing: 'ease-in-out',
    fillMode: 'both',
  },
  new: {
    name: 'new-enter-curtain',
    duration: '400ms',
    easing: 'ease-out',
    fillMode: 'both',
  }
};

const customTransition = {
  forwards: anim,
  backwards: anim,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- OG / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Zentrix Technology`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Zentrix Technology`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.jpg" />

    <link rel="icon" type="image/png" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Zentrix Technology</title>

    <!-- Premium Fonts: Plus Jakarta Sans + Inter + Space Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=Inter:wght@300;400;500;600&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Organization -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Zentrix Technology",
      "url": "https://zentrix-technology.vercel.app",
      "logo": "https://zentrix-technology.vercel.app/logo.png",
      "email": "zentrixtech01@gmail.com",
      "telephone": "+916380957425",
      "description": "Digital Solutions For Real Growth. Web Development, App Development, Digital Marketing, Meta Ads, SEO.",
      "areaServed": "Worldwide",
      "sameAs": [
        "https://www.linkedin.com/company/zentrix-technology"
      ]
    }
    </script>
    <ClientRouter />
  </head>

  <body class="antialiased overflow-x-hidden">

    <!-- Custom Cursor (desktop) -->
    <div id="cursor-dot" aria-hidden="true"></div>
    <div id="cursor-ring" aria-hidden="true"></div>
    <div id="text-spotlight" aria-hidden="true"></div>

    <!-- Page transition curtain -->
    <div class="page-transition" id="page-transition" aria-hidden="true"></div>

    <Header />

    <main class="min-h-screen" style="padding-top:72px;" transition:animate={customTransition}>
      <slot />
    </main>

    <Footer />

    <!-- EmailJS -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>

    <script>
      import Lenis from 'lenis';
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // ── EmailJS creds ──
      const PUBLIC_KEY   = "Hwn19i2dsu59--iK7";
      const SERVICE_ID   = "service_t9v5nqi";
      const TEMPLATE_ID  = "template_871z73a";

      // ── Lenis smooth scroll ──
      let lenis: any;
      const initLenis = () => {
        lenis = new Lenis({
          lerp: 0.07,
          smoothWheel: true,
          wheelMultiplier: 0.9,
          touchMultiplier: 1.5,
        });
        const raf = (time: number) => { lenis?.raf(time); requestAnimationFrame(raf); };
        requestAnimationFrame(raf);
        lenis.on('scroll', () => ScrollTrigger.update());
      };

      // ── Custom magnetic cursor ──
      const initCursor = () => {
        const dot  = document.getElementById('cursor-dot');
        const ring = document.getElementById('cursor-ring');
        const textSpotlight = document.getElementById('text-spotlight');
        if (!dot || !ring) return;

        if (window.matchMedia('(pointer:fine)').matches) {
          let mouseX = 0, mouseY = 0;
          let ringX = 0, ringY = 0;
          let isInitialized = false;

          document.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
            
            if (!isInitialized) {
              document.body.classList.add('has-custom-cursor');
              dot.style.opacity = '1';
              ring.style.opacity = '1';
              if (textSpotlight) textSpotlight.style.opacity = '1';
              ringX = mouseX;
              ringY = mouseY;
              isInitialized = true;
            }
            
            dot.style.left  = mouseX + 'px';
            dot.style.top   = mouseY + 'px';
            if (textSpotlight) {
              textSpotlight.style.left = mouseX + 'px';
              textSpotlight.style.top  = mouseY + 'px';
            }
          });

          // Smooth ring follow (slightly delayed for premium look)
          const animateRing = () => {
            if (isInitialized) {
              ringX += (mouseX - ringX) * 0.12;
              ringY += (mouseY - ringY) * 0.12;
              ring.style.left = ringX + 'px';
              ring.style.top  = ringY + 'px';
            }
            requestAnimationFrame(animateRing);
          };
          animateRing();

          // Hover states
          const addHoverEvents = () => {
            document.querySelectorAll('a, button, [role="button"], .card, .service-card, input, select, textarea').forEach(el => {
              el.addEventListener('mouseenter', () => {
                ring.classList.add('hovering');
                dot.classList.add('hovering');
              });
              el.addEventListener('mouseleave', () => {
                ring.classList.remove('hovering');
                dot.classList.remove('hovering');
              });
            });
          };
          addHoverEvents();

          // Click pulse
          document.addEventListener('mousedown', () => {
            ring.classList.add('clicking');
            dot.style.transform = 'translate(-50%,-50%) scale(0.5)';
          });
          document.addEventListener('mouseup', () => {
            ring.classList.remove('clicking');
            dot.style.transform = 'translate(-50%,-50%) scale(1)';
          });

          // Hide on leave, show on enter
          document.addEventListener('mouseleave', () => {
            if (isInitialized) {
              dot.style.opacity = '0';
              ring.style.opacity = '0';
              if (textSpotlight) textSpotlight.style.opacity = '0';
            }
          });
          document.addEventListener('mouseenter', () => {
            if (isInitialized) {
              dot.style.opacity = '1';
              ring.style.opacity = '1';
              if (textSpotlight) textSpotlight.style.opacity = '1';
            }
          });

          document.addEventListener('astro:page-load', addHoverEvents);
        } else {
          dot.style.display = 'none';
          ring.style.display = 'none';
          if (textSpotlight) textSpotlight.style.display = 'none';
        }
      };

      // ── Metrics counter (bidirectional: resets on scroll back) ──
      const initCounters = () => {
        document.querySelectorAll('[data-counter]').forEach(el => {
          const target = parseInt((el as HTMLElement).dataset['counter'] ?? '0', 10);
          const prefix = (el as HTMLElement).dataset['prefix'] ?? '';
          const suffix = (el as HTMLElement).dataset['suffix'] ?? '';
          let raf: number;
          const animate = (toValue: number, duration: number) => {
            cancelAnimationFrame(raf);
            const startVal = parseFloat(el.textContent?.replace(/[^0-9.]/g, '') || '0');
            const start = performance.now();
            const tick = (now: number) => {
              const progress = Math.min((now - start) / duration, 1);
              const ease = 1 - Math.pow(1 - progress, 4);
              const current = startVal + (toValue - startVal) * ease;
              el.textContent = prefix + Math.round(current) + suffix;
              if (progress < 1) raf = requestAnimationFrame(tick);
            };
            raf = requestAnimationFrame(tick);
          };
          ScrollTrigger.create({
            trigger: el,
            start: 'top 92%',
            toggleActions: 'play none none reverse',
            onEnter: () => animate(target, 1400),
            onLeaveBack: () => animate(0, 600),
          });
        });
      };

      // ── BIDIRECTIONAL SCROLL REVEALS ──
      // toggleActions: 'play none none reverse'
      // → play when entering from bottom (scroll down)
      // → reverse when leaving at bottom (scroll back up past trigger)
      const initReveals = () => {
        ScrollTrigger.getAll().forEach(t => t.kill());

        // ── reveal (from below) ──
        gsap.utils.toArray<HTMLElement>('.reveal').forEach((el) => {
          const delay = parseFloat((el as HTMLElement).dataset['delay'] ?? '0');
          gsap.fromTo(el,
            { opacity: 0, y: 52 },
            {
              opacity: 1, y: 0,
              duration: 0.85,
              delay,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 92%',
                toggleActions: 'play none none reverse',
              }
            }
          );
        });

        // ── reveal-left (from left) ──
        gsap.utils.toArray<HTMLElement>('.reveal-left').forEach((el) => {
          const delay = parseFloat((el as HTMLElement).dataset['delay'] ?? '0');
          gsap.fromTo(el,
            { opacity: 0, x: -72 },
            {
              opacity: 1, x: 0,
              duration: 0.9,
              delay,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 90%',
                toggleActions: 'play none none reverse',
              }
            }
          );
        });

        // ── reveal-right (from right) ──
        gsap.utils.toArray<HTMLElement>('.reveal-right').forEach((el) => {
          const delay = parseFloat((el as HTMLElement).dataset['delay'] ?? '0');
          gsap.fromTo(el,
            { opacity: 0, x: 72 },
            {
              opacity: 1, x: 0,
              duration: 0.9,
              delay,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 90%',
                toggleActions: 'play none none reverse',
              }
            }
          );
        });

        // ── reveal-scale (scale up) ──
        gsap.utils.toArray<HTMLElement>('.reveal-scale').forEach((el) => {
          const delay = parseFloat((el as HTMLElement).dataset['delay'] ?? '0');
          gsap.fromTo(el,
            { opacity: 0, scale: 0.88 },
            {
              opacity: 1, scale: 1,
              duration: 0.8,
              delay,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 90%',
                toggleActions: 'play none none reverse',
              }
            }
          );
        });

        // ── Stagger groups ──
        document.querySelectorAll('.stagger-group').forEach((group) => {
          const children = group.querySelectorAll('.stagger-child');
          gsap.fromTo(children,
            { opacity: 0, y: 40 },
            {
              opacity: 1, y: 0,
              duration: 0.7,
              stagger: 0.1,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: group,
                start: 'top 88%',
                toggleActions: 'play none none reverse',
              }
            }
          );
        });

        // ── Parallax on .parallax-el ──
        gsap.utils.toArray<HTMLElement>('.parallax-el').forEach((el) => {
          const speed = parseFloat((el as HTMLElement).dataset['speed'] ?? '0.2');
          gsap.to(el, {
            yPercent: speed * 100,
            ease: 'none',
            scrollTrigger: {
              trigger: el.closest('section') ?? el,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1.2,
            }
          });
        });

        ScrollTrigger.refresh();
      };

      // ── Contact form ──
      const initContactForm = () => {
        // @ts-ignore
        const emailjs = window.emailjs;
        if (!emailjs) return;
        emailjs.init(PUBLIC_KEY);

        const form        = document.getElementById('contact-form') as HTMLFormElement;
        const successBox  = document.getElementById('form-success');
        const submitBtn   = document.getElementById('submit-btn') as HTMLButtonElement;
        const btnText     = document.getElementById('btn-text');
        const btnLoader   = document.getElementById('btn-loader');
        const resetBtn    = document.getElementById('reset-form');

        if (!form) return;

        form.addEventListener('submit', (e) => {
          e.preventDefault();
          submitBtn.disabled = true;
          if (btnText) btnText.textContent = 'Sending…';
          btnLoader?.classList.remove('hidden');

          const nameVal    = (document.getElementById('name') as HTMLInputElement)?.value;
          const companyVal = (document.getElementById('company') as HTMLInputElement)?.value;
          const emailVal   = (document.getElementById('email') as HTMLInputElement)?.value;
          const budgetVal  = (document.getElementById('budget') as HTMLSelectElement)?.value;
          const msgVal     = (document.getElementById('message') as HTMLTextAreaElement)?.value;

          emailjs.send(SERVICE_ID, TEMPLATE_ID, {
            from_name: nameVal, name: nameVal,
            company: companyVal,
            from_email: emailVal, email: emailVal, reply_to: emailVal,
            budget: budgetVal,
            message: msgVal,
            to_name: 'Zentrix Technology',
          }).then(() => {
            form.classList.add('opacity-0', 'pointer-events-none');
            successBox?.classList.remove('hidden');
            form.reset();
          }).catch((err: any) => {
            console.error(err);
            alert('Send failed — please email us directly at zentrixtech01@gmail.com');
            submitBtn.disabled = false;
            if (btnText) btnText.textContent = 'Send Message →';
            btnLoader?.classList.add('hidden');
          });
        });

        resetBtn?.addEventListener('click', () => {
          form.classList.remove('opacity-0', 'pointer-events-none');
          successBox?.classList.add('hidden');
          submitBtn.disabled = false;
          if (btnText) btnText.textContent = 'Send Message →';
          btnLoader?.classList.add('hidden');
        });
      };



      // ── Status pill close ──
      const initStatusPill = () => {
        document.getElementById('pill-close')?.addEventListener('click', () => {
          const pill = document.getElementById('status-pill');
          if (pill) {
            gsap.to(pill, { height: 0, opacity: 0, duration: 0.3, ease: 'power2.inOut',
              onComplete: () => { pill.style.display = 'none'; }
            });
          }
        });
      };

      // ── Spotlight Hover Tracking ──
      const initSpotlights = () => {
        document.querySelectorAll('.card, .svc-item, .why-icon-box').forEach(el => {
          el.addEventListener('mousemove', (e) => {
            const rect = el.getBoundingClientRect();
            const x = (e as MouseEvent).clientX - rect.left;
            const y = (e as MouseEvent).clientY - rect.top;
            (el as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
            (el as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
          });
        });
      };

      document.addEventListener('astro:page-load', () => {
        if (!lenis) {
          initLenis();
          initCursor();
        } else {
          lenis.start();
          lenis.resize();
          ScrollTrigger.refresh();
        }
        initReveals();
        initCounters();
        initContactForm();
        initStatusPill();
        initSpotlights();

        // Refresh GSAP ScrollTrigger after the view transition animation finishes
        setTimeout(() => {
          ScrollTrigger.refresh();
        }, 750);
      });
    </script>
  </body>
</html>
