---
import { Menu, X } from "lucide-react";
---

<header
  id="site-header"
  class="fixed top-0 left-0 w-full z-50 py-10 px-6 md:px-12 transition-all duration-700 ease-[cubic-bezier(0.23,1,0.32,1)]"
>
  <div class="max-w-[1440px] mx-auto w-full flex items-center justify-between">
    <!-- Left: Logo -->
    <div class="flex items-start">
      <a href="/" class="flex flex-col items-start group">
        <span
          class="text-[12px] font-mono tracking-[0.5em] text-white uppercase opacity-80"
          >Zentrix</span
        >
        <span
          class="text-[8px] font-mono tracking-[0.4em] text-white/30 uppercase mt-1"
          >Technology Collective</span
        >
      </a>
    </div>

    <!-- Right: Navigation (Hidden on mobile) -->
    <nav class="hidden lg:flex items-center gap-16">
      <a
        href="/"
        class="nav-link text-[10px] font-mono tracking-[0.4em] text-white/60 hover:text-white transition-colors uppercase"
        >Home</a
      >
      <a
        href="/services"
        class="nav-link text-[10px] font-mono tracking-[0.4em] text-white/60 hover:text-white transition-colors uppercase"
        >Service</a
      >
      <a
        href="/works"
        class="nav-link text-[10px] font-mono tracking-[0.4em] text-white/60 hover:text-white transition-colors uppercase"
        >Works</a
      >
      <a
        href="/about"
        class="nav-link text-[10px] font-mono tracking-[0.4em] text-white/60 hover:text-white transition-colors uppercase"
        >About</a
      >
      <a
        href="/contact"
        class="px-10 py-4 rounded-full border border-white/20 text-white text-[10px] font-mono tracking-[0.4em] uppercase hover:bg-white hover:text-black transition-all duration-700"
        >Contact</a
      >
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-trigger"
      data-state="closed"
      class="lg:hidden w-12 h-12 flex flex-col items-center justify-center gap-2 focus:outline-none transition-all duration-500 relative z-[70]"
    >
      <span
        class="w-8 h-[1px] bg-white block origin-center transition-transform duration-500"
      ></span>
      <span
        class="w-8 h-[1px] bg-white block origin-center transition-transform duration-500"
      ></span>
    </button>
  </div>

  <!-- Mobile Overlay -->
  <div
    id="mobile-nav-overlay"
    class="fixed inset-0 bg-[#0a0a0a] z-[60] flex flex-col items-center justify-center opacity-0 pointer-events-none transition-all duration-700 ease-[cubic-bezier(0.23,1,0.32,1)]"
  >
    <div class="flex flex-col items-center gap-12">
      <a
        href="/"
        class="mobile-nav-link text-6xl md:text-8xl font-serif italic text-white/20 hover:text-white transition-colors duration-700"
        >Archives</a
      >
      <a
        href="/services"
        class="mobile-nav-link text-6xl md:text-8xl font-serif italic text-white/20 hover:text-white transition-colors duration-700"
        >Verticles</a
      >
      <a
        href="/works"
        class="mobile-nav-link text-6xl md:text-8xl font-serif italic text-white/20 hover:text-white transition-colors duration-700"
        >Selected Works</a
      >
      <a
        href="/about"
        class="mobile-nav-link text-6xl md:text-8xl font-serif italic text-white/20 hover:text-white transition-colors duration-700"
        >The Ethos</a
      >
      <a
        href="/contact"
        class="mobile-nav-link text-6xl md:text-8xl font-serif italic text-white/20 hover:text-white transition-colors duration-700"
        >Contact</a
      >
    </div>
  </div>
</header>

<style>
  .nav-link {
    position: relative;
  }
  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 0;
    height: 1px;
    background: #ffffff;
    transition: width 0.8s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .nav-link:hover::after {
    width: 100%;
  }

  header.scrolled {
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  #mobile-menu-trigger[data-state="open"] span:nth-child(1) {
    transform: translateY(4.5px) rotate(45deg);
    width: 32px;
  }
  #mobile-menu-trigger[data-state="open"] span:nth-child(2) {
    transform: translateY(-4.5px) rotate(-45deg);
    width: 32px;
  }
</style>

<script>
  import gsap from "gsap";

  const initHeader = () => {
    const trigger = document.getElementById("mobile-menu-trigger");
    const overlay = document.getElementById("mobile-nav-overlay");
    const links = document.querySelectorAll(".mobile-nav-link");

    if (!trigger || trigger.getAttribute("data-init")) return;
    trigger.setAttribute("data-init", "true");

    let isOpen = false;

    const toggleMenu = () => {
      isOpen = !isOpen;
      trigger.setAttribute("data-state", isOpen ? "open" : "closed");

      if (isOpen) {
        gsap.to(overlay, {
          opacity: 1,
          pointerEvents: "auto",
          duration: 1,
          ease: "expo.inOut",
        });
        gsap.fromTo(
          links,
          {
            opacity: 0,
            y: 100,
            skewY: 10,
          },
          {
            opacity: 1,
            y: 0,
            skewY: 0,
            duration: 1.5,
            stagger: 0.1,
            ease: "expo.out",
            delay: 0.2,
          },
        );
      } else {
        gsap.to(overlay, {
          opacity: 0,
          pointerEvents: "none",
          duration: 0.8,
          ease: "expo.inOut",
        });
      }
    };

    trigger.addEventListener("click", toggleMenu);

    links.forEach((link) => {
      link.addEventListener("click", () => {
        if (isOpen) toggleMenu();
      });
    });

    const header = document.getElementById("site-header");
    const handleScroll = () => {
      if (window.scrollY > 50) header?.classList.add("scrolled");
      else header?.classList.remove("scrolled");
    };

    window.addEventListener("scroll", handleScroll);
    // Initial check
    handleScroll();
  };

  document.addEventListener("DOMContentLoaded", initHeader);
  // Support Barba navigation
  document.addEventListener("barba_after", initHeader);
</script>
