---
import { Menu, X } from 'lucide-react';
---

<header id="site-header" class="fixed top-0 left-0 w-full z-50 py-8 px-6 md:px-12 transition-all duration-700 ease-[cubic-bezier(0.23,1,0.32,1)]">
  <div class="max-w-[1440px] mx-auto w-full flex items-center justify-between">
    
    <!-- Left: Logo -->
    <div class="flex items-start">
      <a href="/" class="flex flex-col items-start group">
        <div class="relative w-12 h-12 flex items-center justify-center overflow-hidden">
             <img src="/logo.png" alt="Zentrix Logo" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-700 ease-[cubic-bezier(0.23,1,0.32,1)]" />
        </div>
        <span class="mt-2 text-[8px] font-black tracking-[0.4em] text-slate-900 uppercase">Zentrix</span>
      </a>
    </div>

    <!-- Right: Navigation (Hidden on mobile) -->
    <nav class="hidden lg:flex items-center gap-12">
      <a href="/" class="nav-link text-[10px] font-bold tracking-[0.2em] text-slate-500 hover:text-slate-900 transition-colors uppercase">Home</a>
      <a href="/services" class="nav-link text-[10px] font-bold tracking-[0.2em] text-slate-500 hover:text-slate-900 transition-colors uppercase">Services</a>
      <a href="/works" class="nav-link text-[10px] font-bold tracking-[0.2em] text-slate-500 hover:text-slate-900 transition-colors uppercase">Works</a>
      <a href="/about" class="nav-link text-[10px] font-bold tracking-[0.2em] text-slate-500 hover:text-slate-900 transition-colors uppercase">About</a>
      <a href="/contact" class="px-8 py-3 rounded-full bg-slate-900 text-white text-[10px] font-bold tracking-[0.2em] uppercase hover:bg-indigo-600 transition-all duration-500 shadow-xl shadow-slate-200/50">Contact</a>
    </nav>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-trigger" data-state="closed" class="lg:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5 focus:outline-none transition-all duration-500 relative z-[70]">
      <span class="w-6 h-[1.5px] bg-slate-900 block origin-center transition-transform duration-500"></span>
      <span class="w-6 h-[1.5px] bg-slate-900 block origin-center transition-transform duration-500"></span>
      <span class="w-6 h-[1.5px] bg-slate-900 block origin-center transition-transform duration-500"></span>
    </button>
  </div>

  <!-- Mobile Overlay -->
  <div id="mobile-nav-overlay" class="fixed inset-0 bg-white z-[60] flex flex-col items-center justify-center opacity-0 pointer-events-none transition-all duration-700 ease-[cubic-bezier(0.23,1,0.32,1)]">
      <div class="flex flex-col items-center gap-12">
        <a href="/" class="mobile-nav-link text-5xl font-black tracking-tighter text-slate-200 hover:text-slate-900 transition-colors duration-500">Home</a>
        <a href="/services" class="mobile-nav-link text-5xl font-black tracking-tighter text-slate-200 hover:text-slate-900 transition-colors duration-500">Services</a>
        <a href="/works" class="mobile-nav-link text-5xl font-black tracking-tighter text-slate-200 hover:text-slate-900 transition-colors duration-500">Works</a>
        <a href="/about" class="mobile-nav-link text-5xl font-black tracking-tighter text-slate-200 hover:text-slate-900 transition-colors duration-500">About</a>
        <a href="/contact" class="mobile-nav-link text-5xl font-black tracking-tighter text-slate-200 hover:text-slate-900 transition-colors duration-500">Contact</a>
      </div>
  </div>
</header>

<style>
  .nav-link {
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0;
    height: 1px;
    background: #4f46e5;
    transition: width 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .nav-link:hover::after {
    width: 100%;
  }

  header.scrolled {
    padding-top: 1.25rem;
    padding-bottom: 1.25rem;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(15px);
    border-bottom: 1px solid rgba(0,0,0,0.03);
  }

  #mobile-menu-trigger[data-state="open"] span:nth-child(1) { transform: translateY(6px) rotate(45deg); width: 24px; }
  #mobile-menu-trigger[data-state="open"] span:nth-child(2) { opacity: 0; transform: translateX(-10px); }
  #mobile-menu-trigger[data-state="open"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); width: 24px; }
</style>

<script>
    import gsap from 'gsap';

    const initHeader = () => {
        const trigger = document.getElementById('mobile-menu-trigger');
        const overlay = document.getElementById('mobile-nav-overlay');
        const links = document.querySelectorAll('.mobile-nav-link');
        
        // Use a flag to avoid multiple listeners being added
        if (trigger?.getAttribute('data-init')) return;
        trigger?.setAttribute('data-init', 'true');
        
        let isOpen = false;

        const toggleMenu = () => {
            isOpen = !isOpen;
            trigger?.setAttribute('data-state', isOpen ? 'open' : 'closed');
            
            if (isOpen) {
                gsap.to(overlay, { 
                    opacity: 1, 
                    pointerEvents: 'auto', 
                    duration: 0.8,
                    ease: 'power4.inOut'
                });
                gsap.fromTo(links, { 
                    opacity: 0, 
                    y: 100,
                    skewY: 10
                }, {
                    opacity: 1, 
                    y: 0, 
                    skewY: 0,
                    duration: 1.2, 
                    stagger: 0.1, 
                    ease: 'power4.out',
                    delay: 0.1
                });
            } else {
                gsap.to(overlay, { 
                    opacity: 0, 
                    pointerEvents: 'none', 
                    duration: 0.6, 
                    ease: 'power4.inOut'
                });
            }
        };

        trigger?.addEventListener('click', toggleMenu);

        links.forEach(link => {
            link.addEventListener('click', () => {
                if (isOpen) toggleMenu();
            });
        });

        // Scroll listener once
        const header = document.querySelector('header');
        window.addEventListener('scroll', () => {
           if (window.scrollY > 50) header?.classList.add('scrolled');
           else header?.classList.remove('scrolled');
        });
    };

    document.addEventListener('DOMContentLoaded', initHeader);
</script>
