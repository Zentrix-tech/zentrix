---
const pages = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/works', label: 'Work' },
  { href: '/about', label: 'About' },
];
const currentPath = Astro.url.pathname;
---

<header id="site-header" role="banner">
  <div class="container-z header-inner">

    <!-- Logo -->
    <a href="/" class="logo" aria-label="Zentrix Technology Home">
      <img src="/image.png" alt="Zentrix Technology Logo" class="logo-img" />
      <span class="logo-name">Zentrix Technology</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="desktop-nav" aria-label="Main navigation" role="navigation">
      {pages.map(p => (
        <a
          href={p.href}
          class="nav-link"
          aria-current={currentPath === p.href ? 'page' : undefined}
          id={`nav-${p.label.toLowerCase()}`}
        >
          {p.label}
        </a>
      ))}
    </nav>

    <!-- CTA + Hamburger -->
    <div class="header-actions">
      <a href="/contact" class="btn-primary btn-sm" id="nav-contact-cta">
        Let's Talk
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
      </a>
      <button
        id="menu-btn"
        class="hamburger"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-sheet"
      >
        <span class="ham-line"></span>
        <span class="ham-line"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Sheet -->
<div id="sheet-backdrop" aria-hidden="true"></div>
<nav
  id="mobile-sheet"
  role="navigation"
  aria-label="Mobile navigation"
  aria-hidden="true"
>
  <div class="sheet-header">
    <span class="logo" style="pointer-events:none;">
      <img src="/image.png" alt="Zentrix Technology Logo" class="logo-img" />
      <span class="logo-name">Zentrix Technology</span>
    </span>
    <button id="sheet-close" aria-label="Close navigation">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <div class="sheet-links">
    {pages.map(p => (
      <a
        href={p.href}
        class="sheet-link"
        aria-current={currentPath === p.href ? 'page' : undefined}
      >
        {p.label}
      </a>
    ))}
    <a href="/contact" class="sheet-link sheet-link-cta">Contact →</a>
  </div>

  <div class="sheet-footer">
    <p style="font-family:'Space Mono',monospace;font-size:0.62rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--t3);">Get in touch</p>
    <a href="tel:6380957425" style="font-size:1rem;font-weight:700;color:var(--t1);margin-top:0.25rem;display:block;">6380957425</a>
    <a href="mailto:zentrixtech01@gmail.com" style="font-size:0.8rem;color:var(--t2);margin-top:0.25rem;display:block;">zentrixtech01@gmail.com</a>
    <div style="display:flex;align-items:center;gap:0.5rem;margin-top:1rem;">
      <span style="width:7px;height:7px;background:var(--emerald);border-radius:50%;display:inline-block;" class="pulse"></span>
      <span style="font-family:'Space Mono',monospace;font-size:0.58rem;color:var(--t3);letter-spacing:0.08em;text-transform:uppercase;">Accepting projects</span>
    </div>
  </div>
</nav>

<style>
/* ── Header Layout ── */
.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72px;
  gap: 2rem;
}

/* ── Logo ── */
.logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
  flex-shrink: 0;
}
.logo-img {
  height: 34px;
  width: auto;
  border-radius: 6px;
  object-fit: contain;
  transition: transform 300ms, filter 300ms;
}
.logo:hover .logo-img {
  transform: scale(1.05);
  filter: drop-shadow(0 4px 12px var(--v-glow));
}
.logo-name {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.125rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--t1);
  transition: color 200ms;
}
.logo:hover .logo-name { color: var(--v5); }

/* ── Desktop nav ── */
.desktop-nav {
  display: none;
  align-items: center;
  gap: 2.5rem;
  flex: 1;
  justify-content: center;
}
@media (min-width: 768px) { .desktop-nav { display: flex; } }

/* ── Actions ── */
.header-actions { display: flex; align-items: center; gap: 1rem; }
.btn-sm { height: 40px !important; padding: 0 1.25rem !important; font-size: 0.8rem !important; border-radius: 6px !important; }

/* ── Hamburger ── */
.hamburger {
  display: flex; flex-direction: column;
  justify-content: center; align-items: center;
  gap: 5px;
  width: 36px; height: 36px;
  background: transparent; border: none;
  cursor: pointer; padding: 0;
}
@media (min-width: 768px) { .hamburger { display: none; } }
.ham-line {
  display: block; width: 22px; height: 1.5px;
  background: var(--t2);
  transition: transform 300ms var(--expo), opacity 200ms, background 200ms;
}
.hamburger:hover .ham-line { background: var(--t1); }
.hamburger[aria-expanded="true"] .ham-line:first-child { transform: translateY(3.25px) rotate(45deg); }
.hamburger[aria-expanded="true"] .ham-line:last-child { transform: translateY(-3.25px) rotate(-45deg); }

/* ── Mobile Sheet ── */
.sheet-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.25rem 1.75rem;
  border-bottom: 1px solid var(--b1);
}
.sheet-header button {
  background: none; border: none;
  color: var(--t2); cursor: pointer;
  transition: color 150ms;
}
.sheet-header button:hover { color: var(--t1); }
.sheet-links {
  padding: 1rem 0;
}
.sheet-link-cta {
  color: var(--v4) !important;
  border-left-color: transparent !important;
  font-weight: 700;
  margin-top: 0.5rem;
}
.sheet-footer {
  position: absolute; bottom: 2rem; left: 1.75rem;
  padding-bottom: env(safe-area-inset-bottom, 0);
}
</style>

<script>
  const header = document.getElementById('site-header');
  const menuBtn = document.getElementById('menu-btn');
  const sheet = document.getElementById('mobile-sheet');
  const backdrop = document.getElementById('sheet-backdrop');
  const closeBtn = document.getElementById('sheet-close');

  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  const openSheet = () => {
    sheet?.classList.add('open');
    backdrop?.classList.add('open');
    sheet?.setAttribute('aria-hidden', 'false');
    menuBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };
  const closeSheet = () => {
    sheet?.classList.remove('open');
    backdrop?.classList.remove('open');
    sheet?.setAttribute('aria-hidden', 'true');
    menuBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  menuBtn?.addEventListener('click', openSheet);
  closeBtn?.addEventListener('click', closeSheet);
  backdrop?.addEventListener('click', closeSheet);
  sheet?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeSheet));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSheet();
  });
</script>
