---
import { ArrowRight } from 'lucide-react';
---

<footer class="pt-60 pb-20 border-t border-white/10 relative overflow-hidden">
  <div class="absolute inset-0 topographic-lines opacity-10 pointer-events-none"></div>
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-20 mb-40">
      
      <div class="md:col-span-4">
         <a href="/" class="flex flex-col items-start gap-2 group mb-12">
            <span class="text-[14px] font-mono tracking-[0.5em] text-white uppercase">Zentrix</span>
            <span class="text-[9px] font-mono tracking-[0.4em] text-white uppercase opacity-50">Technology Collective</span>
         </a>
         <p class="text-white font-mono text-xs leading-relaxed max-w-sm mb-16">
            Engineering high-performance digital ecosystems for the next generation of global dominance.
         </p>
         <div class="flex items-center gap-8">
            <a href="mailto:zentrixtech01@gmail.com" class="text-[10px] font-mono tracking-[0.4em] text-white hover:opacity-100 transition-opacity uppercase opacity-70">zentrixtech01@gmail.com</a>
         </div>
      </div>
      
      <div class="md:col-span-2 md:col-start-7">
         <h4 class="text-[9px] font-mono tracking-[0.5em] text-white uppercase mb-10 opacity-30">Directory</h4>
         <ul class="space-y-6">
           <li><a href="/" class="text-[10px] font-mono tracking-[0.4em] text-white hover:opacity-100 transition-opacity uppercase opacity-50">Archives</a></li>
           <li><a href="/services" class="text-[10px] font-mono tracking-[0.4em] text-white hover:opacity-100 transition-opacity uppercase opacity-50">Verticles</a></li>
           <li><a href="/works" class="text-[10px] font-mono tracking-[0.4em] text-white hover:opacity-100 transition-opacity uppercase opacity-50">Selected</a></li>
           <li><a href="/about" class="text-[10px] font-mono tracking-[0.4em] text-white hover:opacity-100 transition-opacity uppercase opacity-50">The Ethos</a></li>
         </ul>
      </div>
      
      <div class="md:col-span-4 md:col-start-9">
         <h4 class="text-[9px] font-mono tracking-[0.5em] text-white uppercase mb-10 opacity-30">Ascension</h4>
         <p class="text-white font-mono text-xs mb-12 leading-relaxed opacity-50">Let's discuss how our collective can accelerate your digital sovereignty.</p>
         <a href="/contact" class="inline-flex items-center gap-8 group/cta">
            <span class="w-16 h-16 rounded-full border border-white text-white flex items-center justify-center group-hover/cta:bg-white group-hover/cta:text-black transition-all duration-700">
               <ArrowRight className="w-5 h-5" />
            </span>
            <span class="text-[10px] font-mono tracking-[0.5em] text-white uppercase">Init Inquiry</span>
         </a>
      </div>

    </div>
    
    <div class="flex flex-col md:flex-row items-center justify-between pt-16 border-t border-white/10">
       <p class="text-[9px] font-mono text-white uppercase tracking-[0.4em] opacity-30">© {new Date().getFullYear()} Zentrix Labs. Non-Proprietary Digital Artifact.</p>
       
       <div class="flex items-center gap-12 mt-8 md:mt-0">
          <a href="#" class="text-[9px] font-mono tracking-[0.3em] text-white hover:opacity-60 transition-opacity uppercase opacity-20">Privacy Protocol</a>
          <a href="#" class="text-[9px] font-mono tracking-[0.3em] text-white hover:opacity-60 transition-opacity uppercase opacity-20">Service Terms</a>
       </div>
    </div>
  </div>

  <!-- Smooth WhatsApp Fixed Button (Premium Style) -->
  <a href="https://wa.me/917904645033" target="_blank" rel="noopener noreferrer" class="fixed bottom-12 right-12 z-[100] w-14 h-14 bg-[#25D366] text-white rounded-full flex items-center justify-center shadow-2xl hover:scale-110 transition-all duration-700 group">
