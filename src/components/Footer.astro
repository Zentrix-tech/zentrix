---

<footer class="bg-white pt-40 pb-20 border-t border-slate-100 relative overflow-hidden">
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-20 mb-32">
      
      <div class="md:col-span-4">
         <a href="/" class="flex flex-col items-start gap-4 group mb-10">
            <div class="w-14 h-14 relative overflow-hidden">
                <img src="/logo.png" alt="Zentrix Logo" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-700" />
            </div>
            <span class="text-[10px] font-black tracking-[0.4em] text-slate-900 uppercase">Zentrix Technology</span>
         </a>
         <p class="text-slate-400 font-medium text-sm leading-relaxed max-w-sm mb-12">
            Engineering high-performance digital experiences for the next generation of business.
         </p>
         <div class="flex items-center gap-6">
            <a href="#" class="w-10 h-10 rounded-full border border-slate-100 flex items-center justify-center text-slate-400 hover:border-slate-900 hover:text-slate-900 transition-all duration-500">
               <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            </a>
            <a href="mailto:zentrixtech01@gmail.com" class="text-xs font-black tracking-widest text-slate-900 hover:text-indigo-600 transition-colors">zentrixtech01@gmail.com</a>
         </div>
      </div>
      
      <div class="md:col-span-2 md:col-start-6">
         <h4 class="text-[10px] font-black tracking-[0.4em] text-slate-900 uppercase mb-8">Navigation</h4>
         <ul class="space-y-4">
           <li><a href="/" class="text-[11px] font-bold tracking-[0.2em] text-slate-400 hover:text-slate-900 transition-colors uppercase">Home</a></li>
           <li><a href="/services" class="text-[11px] font-bold tracking-[0.2em] text-slate-400 hover:text-slate-900 transition-colors uppercase">Capabilities</a></li>
           <li><a href="/works" class="text-[11px] font-bold tracking-[0.2em] text-slate-400 hover:text-slate-900 transition-colors uppercase">Works</a></li>
           <li><a href="/about" class="text-[11px] font-bold tracking-[0.2em] text-slate-400 hover:text-slate-900 transition-colors uppercase">Our DNA</a></li>
         </ul>
      </div>
      
      <div class="md:col-span-4">
         <h4 class="text-[10px] font-black tracking-[0.4em] text-slate-900 uppercase mb-8">Ready to evolve?</h4>
         <p class="text-slate-500 font-medium mb-10 leading-relaxed">Let's discuss how our expertise can accelerate your business growth.</p>
         <a href="/contact" class="inline-flex items-center gap-6 group/cta">
            <span class="w-14 h-14 rounded-full bg-slate-900 text-white flex items-center justify-center group-hover/cta:bg-indigo-600 transition-all duration-700">
               <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </span>
            <span class="text-[11px] font-black tracking-[0.4em] text-slate-900 uppercase">Init Discussion</span>
         </a>
      </div>

    </div>
    
    <div class="flex flex-col md:flex-row items-center justify-between pt-12 border-t border-slate-100">
       <p class="text-xs font-medium text-slate-400 mb-6 md:mb-0 uppercase tracking-widest">© {new Date().getFullYear()} Zentrix Tech Labs. All Rights Reserved.</p>
       
       <div class="flex items-center gap-8">
          <a href="#" class="text-[9px] font-bold tracking-[0.2em] text-slate-300 hover:text-slate-900 uppercase transition-colors">Privacy Protcol</a>
          <a href="#" class="text-[9px] font-bold tracking-[0.2em] text-slate-300 hover:text-slate-900 uppercase transition-colors">Terms of Ops</a>
       </div>
    </div>
  </div>

  <!-- Smooth WhatsApp Fixed Button -->
  <a href="https://wa.me/your-number" target="_blank" rel="noopener noreferrer" class="fixed bottom-10 right-10 z-[100] w-14 h-14 bg-emerald-500 text-white rounded-full flex items-center justify-center shadow-2xl shadow-emerald-500/20 hover:scale-110 hover:-translate-y-2 transition-all duration-500 group">
      <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.246 2.248 3.484 5.232 3.483 8.413-.003 6.557-5.338 11.892-11.893 11.892-1.997-.001-3.951-.5-5.688-1.448l-6.308 1.654zm6.215-3.579l.37.22c1.451.863 3.12 1.319 4.827 1.32h11.892.003c5.46 0 9.894-4.434 9.897-9.896.001-2.646-1.03-5.132-2.903-7.003-1.871-1.871-4.358-2.903-7.005-2.904-5.463 0-9.897 4.436-9.9 9.898-.001 1.748.459 3.456 1.328 4.954l.24.417-1.007 3.676 3.766-.988zm12.44-7.054c-.3-.15-1.782-.88-2.057-.98-.273-.1-.473-.15-.673.15-.2.3-.773.98-.948 1.18-.175.2-.35.225-.65.075-.3-.15-1.265-.467-2.41-1.487-.893-.797-1.495-1.782-1.67-2.083-.175-.3-.02-.463.13-.613.135-.133.3-.35.45-.525.15-.175.2-.3.3-.5.1-.2.05-.375-.025-.525-.075-.15-.673-1.62-.923-2.22-.243-.585-.491-.506-.673-.516l-.575-.01c-.2 0-.525.075-.8.375s-1.05 1.025-1.05 2.5 1.075 2.9 1.225 3.1c.15.2 2.112 3.224 5.118 4.524.715.31 1.273.495 1.708.633.717.228 1.368.196 1.884.12.574-.085 1.782-.728 2.032-1.432.25-.705.25-1.308.175-1.433-.075-.125-.275-.2-.575-.35z"/></svg>
  </a>

</footer>
