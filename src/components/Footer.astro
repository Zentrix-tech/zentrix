---
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/works', label: 'Work' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' }
];

const serviceLinks = [
  { href: '/services#web', label: 'Website Development' },
  { href: '/services#app', label: 'Mobile App Development' },
  { href: '/services#software', label: 'Custom Software Development' },
  { href: '/services#hms', label: 'Hospital Management Software' },
  { href: '/services#marketing', label: 'Digital Marketing' },
  { href: '/services#seo', label: 'SEO Services' },
  { href: '/services#meta', label: 'Meta Ads Management' }
];
---
<footer id="site-footer" aria-label="Site footer">
  <div class="container-z">

    <!-- Top: Logo + Newsletter -->
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="logo" aria-label="Zentrix Technology Home">
          <span class="logo-mark" style="width:40px;height:40px;font-size:1.2rem;">Z</span>
          <span class="logo-name" style="font-size:1.35rem;">zentrix</span>
        </a>
        <p class="footer-brand-desc">
          Simple. Smart. Effective.<br/>
          We build digital experiences that drive visibility, quality leads, and real conversions.
        </p>
      </div>

      <div class="footer-newsletter">
        <p class="footer-hdr">Stay Updated</p>
        <p class="footer-sub">Get the latest digital growth strategies in your inbox.</p>
        <form class="nl-form" onsubmit="event.preventDefault();">
          <input type="email" placeholder="Email address..." class="nl-input" required />
          <button type="submit" class="nl-btn" aria-label="Subscribe">→</button>
        </form>
      </div>
    </div>

    <div class="line-sep" style="margin: 3rem 0;"></div>

    <!-- Middle: Links -->
    <div class="footer-mid">
      <div class="f-col">
        <p class="f-title">Company</p>
        <ul class="f-list">
          {navLinks.map(l => <li><a href={l.href} class="f-link">{l.label}</a></li>)}
        </ul>
      </div>

      <div class="f-col">
        <p class="f-title">Services</p>
        <ul class="f-list">
          {serviceLinks.map(l => <li><a href={l.href} class="f-link">{l.label}</a></li>)}
        </ul>
      </div>

      <div class="f-col f-col-contact">
        <p class="f-title">Contact</p>
        <ul class="f-list">
          <li><a href="tel:+916380957425" class="f-link">📞 +91 63809 57425</a></li>
          <li><a href="mailto:zentrixtech01@gmail.com" class="f-link">✉️ zentrixtech01@gmail.com</a></li>
          <li style="margin-top:1rem;">
            <div style="display:flex;align-items:center;gap:0.5rem;">
              <span style="width:6px;height:6px;background:var(--v4);border-radius:50%;" class="pulse"></span>
              <span style="font-family:'Space Mono',monospace;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.05em;color:var(--t3);">Accepting Projects</span>
            </div>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom: Legal -->
    <div class="footer-bot">
      <p class="f-copy">© {currentYear} Zentrix Technology. All rights reserved.</p>
      <div class="f-legal">
        <a href="/privacy" class="f-link">Privacy Policy</a>
        <a href="/terms" class="f-link">Terms of Service</a>
      </div>
    </div>

  </div>
</footer>

<style>
#site-footer {
  background: var(--void);
  padding: clamp(4rem, 8vw, 6rem) 0 2rem;
  border-top: 1px solid var(--b1);
  position: relative;
  overflow: hidden;
}
/* Subtle top glow */
#site-footer::before {
  content: '';
  position: absolute;
  top: 0; left: 10%; right: 10%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(124,58,237,0.3), rgba(6,182,212,0.3), transparent);
}

.footer-top {
  display: flex; flex-direction: column; gap: 3rem;
  justify-content: space-between;
}
@media (min-width: 768px) { .footer-top { flex-direction: row; align-items: flex-start; } }

.footer-brand-desc {
  margin-top: 1.25rem;
  color: var(--t2); font-size: 0.9375rem; line-height: 1.7;
  max-width: 320px;
}

.footer-newsletter { max-width: 340px; }
.footer-hdr { font-size: 1.125rem; font-weight: 700; color: var(--t1); margin-bottom: 0.5rem; }
.footer-sub { color: var(--t3); font-size: 0.875rem; margin-bottom: 1.25rem; }
.nl-form {
  display: flex; align-items: center;
  background: var(--surface);
  border: 1px solid var(--b2);
  border-radius: 8px;
  padding: 4px;
  transition: border-color 200ms;
}
.nl-form:focus-within { border-color: var(--v3); }
.nl-input {
  flex: 1; background: transparent; border: none;
  padding: 0.625rem 1rem; color: var(--t1); font-size: 0.875rem;
  outline: none;
}
.nl-input::placeholder { color: var(--t3); }
.nl-btn {
  width: 36px; height: 36px;
  background: var(--v-dim); color: var(--v4);
  border: 1px solid var(--v-border); border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: background 200ms, color 200ms;
}
.nl-btn:hover { background: var(--v3); color: #fff; }

.footer-mid {
  display: grid; grid-template-columns: 1fr; gap: 2.5rem;
}
@media (min-width: 500px) { .footer-mid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 768px) { .footer-mid { grid-template-columns: repeat(3, 1fr); } }

.f-title {
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--t1); margin-bottom: 1.25rem;
}
.f-list { list-style: none; display: flex; flex-direction: column; gap: 0.875rem; }
.f-link {
  color: var(--t2); font-size: 0.9375rem; transition: color 200ms;
  display: inline-flex; align-items: center;
}
.f-link:hover { color: var(--v4); }

.footer-bot {
  margin-top: 4rem; padding-top: 2rem;
  border-top: 1px solid var(--b1);
  display: flex; flex-direction: column; gap: 1.25rem;
  justify-content: space-between; align-items: center;
  text-align: center;
}
@media (min-width: 768px) { .footer-bot { flex-direction: row; text-align: left; } }
.f-copy { font-family: 'Space Mono', monospace; font-size: 0.65rem; color: var(--t3); letter-spacing: 0.05em; }
.f-legal { display: flex; gap: 1.5rem; }
.f-legal .f-link { font-family: 'Space Mono', monospace; font-size: 0.65rem; color: var(--t3); letter-spacing: 0.05em; }
.f-legal .f-link:hover { color: var(--t1); }
</style>
