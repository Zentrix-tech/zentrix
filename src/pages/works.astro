---
import Layout from '../layouts/Layout.astro';

const projects = [
  { id: 1, title: 'E-Commerce Platform', category: 'Web Development', desc: 'A high-converting headless e-commerce experience built for a premium lifestyle brand. Increased conversions by 45%.', image: 'https://images.unsplash.com/photo-1661956602116-aa6865609028?auto=format&fit=crop&q=80&w=800&h=600', tags: ['Next.js', 'Shopify Plus', 'Framer Motion'], color: 'var(--v4)' },
  { id: 2, title: 'Fintech Mobile App', category: 'App Development', desc: 'A secure, intuitive personal finance app for iOS and Android. Reached 100k+ downloads in the first month.', image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&q=80&w=800&h=600', tags: ['React Native', 'Node.js', 'AWS'], color: 'var(--v5)' },
  { id: 3, title: 'B2B SaaS Marketing', category: 'Digital Marketing', desc: 'Comprehensive inbound marketing strategy that generated a 3x increase in qualified enterprise leads.', image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=800&h=600', tags: ['Content Strategy', 'HubSpot', 'SEO'], color: 'var(--v3)' },
  { id: 4, title: 'Real Estate Meta Ads', category: 'Meta Ads', desc: 'Targeted lead generation campaign that reduced cost-per-lead by 60% while improving lead quality.', image: 'https://images.unsplash.com/photo-1560518883-ce09059eeffa?auto=format&fit=crop&q=80&w=800&h=600', tags: ['Facebook Ads', 'Retargeting', 'Lead Gen'], color: 'var(--v4)' },
];
---
<Layout title="Our Work" description="Explore our portfolio of successful digital projects. See how Zentrix Technology helps businesses achieve real growth through web, app, and marketing solutions.">

<!-- Hero -->
<section class="work-hero" aria-labelledby="work-h1">
  <div class="blob blob-violet" style="width:700px;height:700px;top:-200px;left:-150px;opacity:0.45;" aria-hidden="true"></div>
  <div class="blob blob-cyan" style="width:500px;height:500px;bottom:-100px;right:-100px;opacity:0.3;" aria-hidden="true"></div>
  <div class="bg-grid" style="position:absolute;inset:0;pointer-events:none;" aria-hidden="true"></div>

  <div class="container-z stagger-group" style="position:relative;z-index:2;text-align:center;">
    <p class="label stagger-child" style="justify-content:center;">Our Portfolio</p>
    <h1 id="work-h1" class="stagger-child" style="font-size:var(--display);font-weight:800;letter-spacing:-0.05em;line-height:1.03;margin:1.25rem 0 1.5rem;">
      Featured <span class="text-gradient">Work</span>
    </h1>
    <p class="stagger-child" style="font-size:1.125rem;color:var(--t2);max-width:500px;margin:0 auto 2.5rem;line-height:1.8;">
      A selection of our best projects showcasing digital solutions that drive real business results.
    </p>
  </div>
</section>

<!-- Projects Grid -->
<section style="padding:clamp(4rem,7vw,7rem) 0;" aria-label="Projects grid">
  <div class="container-z">
    <div class="work-grid">
      {projects.map((p, i) => (
        <div class="work-card reveal" data-delay={`${(i % 2) * 0.1}`}>
          <!-- Image Container -->
          <div class="work-img-wrap">
            <img src={p.image} alt={p.title} class="work-img" loading="lazy" />
            <div class="work-overlay" style={`background:linear-gradient(to top, rgba(5,8,15,0.9), transparent);`}></div>
            <div class="work-category-tag" style={`background:${p.color}15;color:${p.color};border:1px solid ${p.color}30;`}>
              {p.category}
            </div>
          </div>
          <!-- Content -->
          <div class="work-content">
            <h2 class="work-title">{p.title}</h2>
            <p class="work-desc">{p.desc}</p>
            <div class="work-tags">
              {p.tags.map(t => <span class="tech-tag" style={`color:${p.color};border-color:${p.color}30;background:${p.color}10;`}>{t}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section style="padding:var(--section-y) 0;background:var(--void);text-align:center;position:relative;overflow:hidden;" aria-labelledby="work-cta-h">
  <div class="blob blob-violet" style="width:600px;height:600px;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0.4;" aria-hidden="true"></div>
  <div class="container-z stagger-group" style="position:relative;z-index:1;">
    <p class="label stagger-child" style="justify-content:center;">Ready to grow?</p>
    <h2 id="work-cta-h" class="stagger-child" style="font-size:var(--h1);font-weight:800;letter-spacing:-0.04em;max-width:16ch;margin:1rem auto 2rem;">
      Your Project Could Be <span class="text-gradient">Next</span>
    </h2>
    <div class="stagger-child" style="display:flex;justify-content:center;flex-wrap:wrap;gap:1rem;">
      <a href="/contact" class="btn-primary" id="work-final-cta">Start Your Project →</a>
    </div>
  </div>
</section>

</Layout>

<style>
.work-hero {
  position: relative; overflow: hidden;
  padding: clamp(7rem,13vw,10rem) 0 clamp(4rem,7vw,6rem);
}
.work-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3.5rem;
}
@media (min-width: 768px) {
  .work-grid { grid-template-columns: 1fr 1fr; gap: 4rem 2.5rem; }
}

/* ── Work Card ── */
.work-card {
  display: flex; flex-direction: column; gap: 1.5rem;
  group: work; /* logical group */
}
.work-img-wrap {
  position: relative;
  aspect-ratio: 4/3;
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid var(--b1);
  background: var(--surface);
  transition: border-color 400ms, transform 400ms var(--expo), box-shadow 400ms;
}
.work-card:hover .work-img-wrap {
  border-color: rgba(124,58,237,0.3);
  transform: translateY(-8px);
  box-shadow: 0 40px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(124,58,237,0.1);
}
.work-img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 600ms var(--expo), filter 600ms;
  filter: grayscale(10%) contrast(1.1);
}
.work-card:hover .work-img {
  transform: scale(1.05);
  filter: grayscale(0%) contrast(1.1);
}
.work-overlay {
  position: absolute; inset: 0;
  pointer-events: none;
  opacity: 0.6;
  transition: opacity 400ms;
}
.work-card:hover .work-overlay { opacity: 0.8; }
.work-category-tag {
  position: absolute; top: 1.25rem; left: 1.25rem;
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  padding: 0.35rem 0.875rem;
  border-radius: 100px;
  backdrop-filter: blur(8px);
  z-index: 2;
}
.work-content { display: flex; flex-direction: column; gap: 0.875rem; }
.work-title {
  font-size: 1.5rem; font-weight: 800; letter-spacing: -0.03em;
  color: var(--t1); line-height: 1.2;
  transition: color 200ms;
}
.work-card:hover .work-title { color: var(--v5); }
.work-desc {
  font-size: 0.9375rem; color: var(--t2); line-height: 1.7;
}
.work-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }
</style>
