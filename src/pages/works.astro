---
import Layout from '../layouts/Layout.astro';
import { ArrowRight, CheckCircle2 } from 'lucide-react';

const cases = [
  {
    title: "FinCore Analytics",
    category: "App Ecosystem",
    tagline: "Ultra-fast financial intelligence for institutional investors.",
    problem: "A major financial startup struggled with legacy data processing systems that took minutes to generate risk reports.",
    solution: "We re-architected their entire frontend using a performance-first reactive framework and implemented WebSockets.",
    outcome: [
      "94% reduction in dashboard latency",
      "Real-time institutional streaming",
      "Successful Series B funding round"
    ],
    symbol: "FC"
  },
  {
    title: "Lumina Health",
    category: "Web Infrastructure",
    tagline: "Connecting patient care records with zero-trust safety.",
    problem: "A regional hospital network relied on disjointed, internal systems for patient onboarding, leading to data loss.",
    solution: "We designed and built a highly secure, unified patient portal integrating with their legacy database securely.",
    outcome: [
      "Zero compliance breaches since launch",
      "HIPAA compliant architecture",
      "70% reduction in admin overhead"
    ],
    symbol: "LH"
  },
  {
    title: "EcoFuture Portal",
    category: "Growth Platform",
    tagline: "Converting sustainable energy traffic into enterprise contracts.",
    problem: "A sustainable energy provider had an archaic B2B platform that was difficult to navigate and convert.",
    solution: "Zentrix delivered an end-to-end transformation. We completely rebuilt their frontend to be intuitive.",
    outcome: [
      "315% increase in B2B qualified leads",
      "Custom enterprise funnel optimization",
      "Ranked #1 for target industry keywords"
    ],
    symbol: "EF"
  }
];
---

<Layout title="Works">
  
  <section class="pt-60 pb-32 relative overflow-hidden">
     <div class="absolute inset-0 topographic-lines opacity-10 pointer-events-none"></div>
     <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-4xl section-reveal">
           <span class="text-[10px] font-mono tracking-[0.5em] text-white uppercase mb-8 block">Project Archives</span>
           <h1 class="text-7xl md:text-9xl font-serif italic text-white mb-10 leading-[0.85] reveal-up">Selected <br/><span class="text-white not-italic">Artifacts.</span></h1>
           <p class="text-xl text-white font-mono leading-relaxed max-w-2xl reveal-up">
              A curated documentation of engineering challenges solved and digital sovereignty established for our partners.
           </p>
        </div>
     </div>
  </section>

  <section class="pb-60">
    <div class="container mx-auto px-6">
      <div class="space-y-60">
        {cases.map((caseStudy, index) => (
          <div class="work-block reveal-on-scroll">
             <div class={`flex flex-col ${index % 2 !== 0 ? 'lg:flex-row-reverse' : 'lg:flex-row'} gap-20 lg:gap-32 items-center`}>
                
                <!-- Visual Container -->
                <div class="w-full lg:w-3/5 group">
                   <div class="relative rounded-[1rem] overflow-hidden aspect-[16/10] bg-black/40 border border-white/20 transition-all duration-1000 group-hover:border-white">
                      <div class="absolute inset-0 flex items-center justify-center overflow-hidden">
                          <!-- Abstract Symbol -->
                          <div class="text-[15vw] font-serif italic text-white select-none opacity-20 tracking-tighter transform group-hover:scale-110 group-hover:opacity-40 transition-transform duration-[2s]">
                             {caseStudy.symbol}
                          </div>
                      </div>
                      
                      <!-- Overlay info on image -->
                      <div class="absolute bottom-12 left-12 opacity-0 transform translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-1000">
                         <span class="text-[10px] font-mono tracking-[0.5em] text-black uppercase bg-white px-8 py-4 rounded-full">Archive View</span>
                      </div>
                   </div>
                </div>

                <!-- Content Area -->
                <div class="w-full lg:w-2/5">
                   <div class="flex items-center gap-6 mb-10">
                      <span class="text-[9px] font-mono tracking-[0.4em] text-white uppercase">{caseStudy.category}</span>
                      <div class="w-12 h-[1px] bg-white"></div>
                   </div>
                   
                   <h2 class="text-5xl md:text-6xl font-serif italic text-white mb-8 tracking-tight leading-none">{caseStudy.title}</h2>
                   <p class="text-lg text-white font-mono mb-12">"{caseStudy.tagline}"</p>
                   
                   <div class="space-y-12">
                      <div class="case-meta-item">
                         <h4 class="text-[9px] font-mono tracking-[0.5em] text-white uppercase mb-4">The Challenge</h4>
                         <p class="text-white font-mono text-sm leading-relaxed">{caseStudy.problem}</p>
                      </div>
                      
                      <div class="case-meta-item">
                         <h4 class="text-[9px] font-mono tracking-[0.5em] text-white uppercase mb-4">The Solution</h4>
                         <p class="text-white font-mono text-sm leading-relaxed">{caseStudy.solution}</p>
                      </div>

                      <div class="pt-10 border-t border-white/10">
                         <h4 class="text-[9px] font-mono tracking-[0.5em] text-white uppercase mb-8">Key Metrics</h4>
                         <ul class="space-y-6">
                            {caseStudy.outcome.map((res) => (
                               <li class="flex items-start gap-4 text-xs font-mono text-white">
                                  <ArrowRight className="w-4 h-4 text-white shrink-0" />
                                  {res}
                               </li>
                            ))}
                         </ul>
                      </div>
                   </div>
                </div>
             </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-60 mx-6 mb-32 rounded-[1rem] relative overflow-hidden border border-white/10">
      <div class="absolute inset-0 topographic-lines opacity-10 pointer-events-none"></div>
      <div class="container mx-auto px-6 text-center max-w-4xl relative z-10">
         <h2 class="text-6xl md:text-8xl font-serif italic text-white tracking-tight mb-16 leading-none">Built to scale. <br/><span class="not-italic text-white">Ready to win?</span></h2>
         <a href="/contact" class="inline-flex items-center justify-center px-16 py-8 bg-white text-black rounded-full text-[11px] font-mono tracking-[0.6em] uppercase hover:scale-105 transition-all duration-700">
            Init Project
         </a>
      </div>
  </section>

</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    // Entrance Animations
    gsap.from('.reveal-up', {
      y: 100,
      opacity: 0,
      duration: 1.5,
      stagger: 0.2,
      ease: 'expo.out'
    });

    // Scroll Revelations
    const blocks = document.querySelectorAll('.work-block');
    blocks.forEach(block => {
      gsap.from(block, {
        y: 100,
        opacity: 0,
        duration: 1.5,
        ease: 'expo.out',
        scrollTrigger: {
          trigger: block,
          start: 'top 85%',
          toggleActions: 'play none none none'
        }
      });
    });
  });

  document.addEventListener('barba_after', () => {
     ScrollTrigger.refresh();
  });
</script>
