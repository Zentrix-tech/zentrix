---
import Layout from '../layouts/Layout.astro';
import { Layers, Smartphone, Megaphone, CheckCircle2, ArrowRight } from 'lucide-react';
---

<Layout title="Services">
  
  <section class="pt-60 pb-32 relative overflow-hidden">
     <div class="absolute inset-0 topographic-lines opacity-10 pointer-events-none"></div>
     <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-4xl section-reveal">
           <span class="text-[10px] font-mono tracking-[0.5em] text-white uppercase mb-8 block">Engineering Core</span>
           <h1 class="text-7xl md:text-9xl font-serif italic text-white mb-10 leading-[0.85] reveal-up">Digital <br/><span class="text-white not-italic">Capabilities.</span></h1>
           <p class="text-xl text-white font-mono leading-relaxed max-w-2xl reveal-up">
             We deliver specialized technology solutions that bridge the gap between technical complexity and business growth.
           </p>
        </div>
     </div>
  </section>

  <!-- Capability Blocks -->
  <section class="pb-60">
    <div class="container mx-auto px-6">
      
      <!-- Web Capability -->
      <div class="py-5 border-t border-white/10 bg-black/20 group transition-colors duration-700 reveal-on-scroll">
         <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 py-20 px-4 md:px-10">
            <div class="lg:col-span-1">
               <span class="text-xs font-mono text-white group-hover:text-white transition-colors">01</span>
            </div>
            <div class="lg:col-span-4">
               <h2 class="text-4xl md:text-6xl font-serif italic text-white mb-8 group-hover:translate-x-4 transition-transform duration-700">Web Systems</h2>
               <div class="flex flex-wrap gap-3">
                  <span class="text-[8px] font-mono tracking-[0.2em] text-white border border-white/20 px-4 py-1.5 rounded-full uppercase">React / Next.js</span>
                  <span class="text-[8px] font-mono tracking-[0.2em] text-white border border-white/20 px-4 py-1.5 rounded-full uppercase">Astro Engine</span>
               </div>
            </div>
            <div class="lg:col-span-5 lg:col-start-7">
               <p class="text-lg text-white font-mono leading-relaxed mb-10">
                  Engineering high-velocity web platforms with a focus on core web vitals, accessibility, and sub-second interaction times. We build for performance first.
               </p>
               <ul class="space-y-4 mb-20">
                  <li class="flex items-center gap-4 text-sm font-mono text-white">
                     <CheckCircle2 className="w-4 h-4 text-white" /> Jamstack Architecture
                  </li>
                  <li class="flex items-center gap-4 text-sm font-mono text-white">
                     <CheckCircle2 className="w-4 h-4 text-white" /> Custom E-commerce
                  </li>
                  <li class="flex items-center gap-4 text-sm font-mono text-white">
                     <CheckCircle2 className="w-4 h-4 text-white" /> Enterprise SEO
                  </li>
               </ul>
               <a href="/works" class="inline-flex items-center gap-6 group/at">
                  <div class="w-14 h-14 rounded-full border border-white text-white flex items-center justify-center group-hover/at:bg-white group-hover/at:text-black transition-all duration-700">
                     <ArrowRight className="w-5 h-5" />
                  </div>
                  <span class="text-[10px] font-mono tracking-[0.3em] uppercase text-white">Archives</span>
               </a>
            </div>
         </div>
      </div>

      <!-- Mobile Capability -->
      <div class="py-5 border-t border-white/10 bg-black/20 group transition-colors duration-700 reveal-on-scroll">
         <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 py-20 px-4 md:px-10">
            <div class="lg:col-span-1">
               <span class="text-xs font-mono text-white group-hover:text-white transition-colors">02</span>
            </div>
            <div class="lg:col-span-4">
               <h2 class="text-4xl md:text-6xl font-serif italic text-white mb-8 group-hover:translate-x-4 transition-transform duration-700">Mobile Hub</h2>
               <div class="flex flex-wrap gap-3">
                  <span class="text-[8px] font-mono tracking-[0.2em] text-white border border-white/20 px-4 py-1.5 rounded-full uppercase">React Native</span>
                  <span class="text-[8px] font-mono tracking-[0.2em] text-white border border-white/20 px-4 py-1.5 rounded-full uppercase">ios / android</span>
               </div>
            </div>
            <div class="lg:col-span-5 lg:col-start-7">
               <p class="text-lg text-white font-mono leading-relaxed mb-10">
                  Immersive mobile experiences that maximize user retention. From initial prototype to store deployment, we manage the entire lifecycle with native-feel performance.
               </p>
               <ul class="space-y-4 mb-20">
                  <li class="flex items-center gap-4 text-sm font-mono text-white">
                     <CheckCircle2 className="w-4 h-4 text-white" /> Cross-Platform Sync
                  </li>
                  <li class="flex items-center gap-4 text-sm font-mono text-white">
                     <CheckCircle2 className="w-4 h-4 text-white" /> Real-time Data
                  </li>
                  <li class="flex items-center gap-4 text-sm font-mono text-white">
                     <CheckCircle2 className="w-4 h-4 text-white" /> Biometrics integration
                  </li>
               </ul>
               <a href="/contact" class="inline-flex items-center gap-6 group/at">
                  <div class="w-14 h-14 rounded-full border border-white text-white flex items-center justify-center group-hover/at:bg-white group-hover/at:text-black transition-all duration-700">
                     <ArrowRight className="w-5 h-5" />
                  </div>
                  <span class="text-[10px] font-mono tracking-[0.3em] uppercase text-white">Discovery</span>
               </a>
            </div>
         </div>
      </div>

      <!-- Marketing Capability -->
      <div class="py-5 border-y border-white/10 bg-black/20 group transition-colors duration-700 reveal-on-scroll">
         <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 py-20 px-4 md:px-10">
            <div class="lg:col-span-1">
               <span class="text-xs font-mono text-white group-hover:text-white transition-colors">03</span>
            </div>
            <div class="lg:col-span-4">
               <h2 class="text-4xl md:text-6xl font-serif italic text-white mb-8 group-hover:translate-x-4 transition-transform duration-700">Growth Engine</h2>
               <div class="flex flex-wrap gap-3">
                  <span class="text-[8px] font-mono tracking-[0.2em] text-white border border-white/20 px-4 py-1.5 rounded-full uppercase">performance ad</span>
                  <span class="text-[8px] font-mono tracking-[0.2em] text-white border border-white/20 px-4 py-1.5 rounded-full uppercase">data analytics</span>
               </div>
            </div>
            <div class="lg:col-span-5 lg:col-start-7">
               <p class="text-lg text-white font-mono leading-relaxed mb-10">
                  Data-driven acquisition strategies that focus on customer LTV and brand equity. We track every interaction to optimize your conversion funnel for maximum yield.
               </p>
               <ul class="space-y-4 mb-20">
                  <li class="flex items-center gap-4 text-sm font-mono text-white">
                     <CheckCircle2 className="w-4 h-4 text-white" /> Multivariate A/B Testing
                  </li>
                  <li class="flex items-center gap-4 text-sm font-mono text-white">
                     <CheckCircle2 className="w-4 h-4 text-white" /> Multi-channel Ads
                  </li>
                  <li class="flex items-center gap-4 text-sm font-mono text-white">
                     <CheckCircle2 className="w-4 h-4 text-white" /> SEO Content
                  </li>
               </ul>
               <a href="/contact" class="inline-flex items-center gap-6 group/at">
                  <div class="w-14 h-14 rounded-full border border-white text-white flex items-center justify-center group-hover/at:bg-white group-hover/at:text-black transition-all duration-700">
                     <ArrowRight className="w-5 h-5" />
                  </div>
                  <span class="text-[10px] font-mono tracking-[0.3em] uppercase text-white">Scale</span>
               </a>
            </div>
         </div>
      </div>

    </div>
  </section>

  <!-- Process Section -->
  <section class="py-40">
     <div class="container mx-auto px-6">
        <div class="flex flex-col lg:flex-row gap-20">
           <div class="lg:w-1/3">
              <span class="text-[10px] font-mono tracking-[0.5em] text-white uppercase mb-6 block">Execution</span>
              <h2 class="text-5xl md:text-7xl font-serif text-white leading-none">The Zentrix <br/><span class="italic text-white">Protocol.</span></h2>
           </div>
           <div class="lg:w-2/3 grid grid-cols-1 md:grid-cols-2 gap-1">
              <div class="p-12 border border-white/10 hover:bg-white/10 transition-all duration-500 reveal-on-scroll">
                 <h3 class="text-xl font-serif italic text-white mb-6">01. Discovery</h3>
                 <p class="text-sm font-mono text-white leading-relaxed">Deep-dive into business logic, user personas, and scaling requirements.</p>
              </div>
              <div class="p-12 border border-white/10 hover:bg-white/10 transition-all duration-500 reveal-on-scroll">
                 <h3 class="text-xl font-serif italic text-white mb-6">02. Engineering</h3>
                 <p class="text-sm font-mono text-white leading-relaxed">High-velocity development cycles with weekly checkpoints and rapid iteration.</p>
              </div>
              <div class="p-12 border border-white/10 hover:bg-white/10 transition-all duration-500 reveal-on-scroll">
                 <h3 class="text-xl font-serif italic text-white mb-6">03. Validation</h3>
                 <p class="text-sm font-mono text-white leading-relaxed">Rigorous performance auditing, security penetration testing, and UAT.</p>
              </div>
              <div class="p-12 border border-white/10 hover:bg-white/10 transition-all duration-500 reveal-on-scroll">
                 <h3 class="text-xl font-serif italic text-white mb-6">04. Expansion</h3>
                 <p class="text-sm font-mono text-white leading-relaxed">Post-launch growth monitoring, infrastructure scaling, and feature rollout.</p>
              </div>
           </div>
        </div>
     </div>
  </section>

</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    // Entrance Animations
    gsap.from('.reveal-up', {
      y: 100,
      opacity: 0,
      duration: 1.5,
      stagger: 0.2,
      ease: 'expo.out'
    });

    // Scroll Revelations
    const reveals = document.querySelectorAll('.reveal-on-scroll');
    reveals.forEach(el => {
      gsap.from(el, {
        y: 60,
        opacity: 0,
        duration: 1.2,
        ease: 'expo.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          toggleActions: 'play none none none'
        }
      });
    });
  });

  document.addEventListener('barba_after', () => {
     ScrollTrigger.refresh();
  });
</script>
