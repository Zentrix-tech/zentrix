---
import Layout from '../layouts/Layout.astro';

const services = [
  { 
    id: 'web',  
    num: '01', 
    emoji: '🖥️', 
    title: 'Website Development', 
    color: 'var(--v4)', 
    colorDim: 'var(--v-dim)',  
    colorBorder: 'var(--v-border)',  
    desc: 'High-performance website development in Salem. We construct custom, responsive websites optimized for Google Core Web Vitals, SEO structure, and maximum lead conversion. From corporate landing pages to complex headless commerce platforms.', 
    tags: ['React', 'Next.js', 'Astro', 'TypeScript', 'TailwindCSS'],  
    features: ['Custom Web Design & Development', 'SEO-first responsive structures', 'E-commerce & Headless Architecture', 'Performance optimization (LCP < 2.5s)', 'CMS Integration (WordPress, Shopify, Strapi)'] 
  },
  { 
    id: 'app',  
    num: '02', 
    emoji: '📱', 
    title: 'Mobile App Development', 
    color: 'var(--v5)', 
    colorDim: 'var(--v-dim)',   
    colorBorder: 'var(--v-border)',   
    desc: 'Premium mobile application development in Salem. We build native iOS and Android apps using cross-platform frameworks to ensure a flawless experience, rapid deployment, and budget compliance.', 
    tags: ['React Native', 'Flutter', 'iOS', 'Android', 'Firebase'],  
    features: ['Custom iOS & Android Application Design', 'Cross-Platform development workflows', 'Intelligent Mobile UI/UX layouts', 'Secure API Integration & Backends', 'App Store and Google Play deployment'] 
  },
  { 
    id: 'software',  
    num: '03', 
    emoji: '⚙️', 
    title: 'Custom Software Development', 
    color: 'var(--v3)', 
    colorDim: 'var(--v-dim)',   
    colorBorder: 'var(--v-border)',   
    desc: 'Automate operations with custom software development in Salem. We design enterprise-grade CRM, ERP, invoicing portals, and SaaS platforms tailored to fit your specific business processes and eliminate structural bottlenecks.', 
    tags: ['Node.js', 'Python', 'PostgreSQL', 'AWS Cloud', 'Docker'],  
    features: ['Tailored CRM & ERP Solutions', 'SaaS Platform architecture', 'Cloud Infrastructure configuration', 'Legacy database migrations', 'Secure API & microservice pipelines'] 
  },
  { 
    id: 'hms',  
    num: '04', 
    emoji: '🏥', 
    title: 'Hospital Management Software (HMS)', 
    color: 'var(--v4)', 
    colorDim: 'var(--v-dim)',   
    colorBorder: 'var(--v-border)',   
    desc: 'All-in-one Hospital Management Software in Tamil Nadu. Automate doctor scheduling, patient outpatient/inpatient billing, digital prescriptions, pharmacy stock tracking, and laboratory reporting via a highly secure, easy-to-use clinic management dashboard.', 
    tags: ['Healthcare IT', 'Security Protocols', 'EMR Systems', 'Patient Portal'],  
    features: ['EHR / EMR Patients Records Management', 'OPD / IPD Billing & Invoicing Systems', 'Doctor Appointment Scheduling', 'Pharmacy & Lab Stock automation', 'Automated SMS / WhatsApp alerts'] 
  },
  { 
    id: 'marketing',  
    num: '05', 
    emoji: '📣', 
    title: 'Digital Marketing', 
    color: 'var(--v3)', 
    colorDim: 'var(--v-dim)',  
    colorBorder: 'var(--v-border)',  
    desc: 'Data-backed digital marketing agency services in Salem. We orchestrate comprehensive campaigns spanning content marketing, email workflows, and social media to scale brand reach and drive organic interest.', 
    tags: ['Content Strategy', 'Email Marketing', 'Social Media', 'Google Analytics'], 
    features: ['Content marketing & scheduling', 'Automated email nurture flows', 'Social Media Management (SMM)', 'Targeted brand architecture', 'Funnel analysis & growth audit'] 
  },
  { 
    id: 'seo',  
    num: '06', 
    emoji: '🔍', 
    title: 'SEO Services', 
    color: 'var(--v5)', 
    colorDim: 'var(--v-dim)',  
    colorBorder: 'var(--v-border)',  
    desc: 'Dominate organic local search keywords with our SEO company in Salem. We perform technical site audits, clean code syntax, configure structured schemas, and construct contextual backlinks to rank your business page high on Google search results.', 
    tags: ['Technical SEO', 'Keyword Analysis', 'Local SEO Salem', 'Link Building'], 
    features: ['Technical site auditing & repair', 'Targeted local keyword strategy', 'Perfect H1-H3 Heading Optimization', 'Structured data & schema configuration', 'Monthly SEO ranking performance logs'] 
  },
  { 
    id: 'meta', 
    num: '07', 
    emoji: '🎯', 
    title: 'Meta Ads Management', 
    color: 'var(--v4)', 
    colorDim: 'var(--v-dim)',  
    colorBorder: 'var(--v-border)',  
    desc: 'Result-oriented paid advertising in Salem. Our Meta ads management configures optimized target audiences, designs custom visual ad sets, runs precise A/B split testing, and decreases cost-per-acquisition on Facebook and Instagram.', 
    tags: ['Facebook Ads', 'Instagram Ads', 'A/B Testing', 'ROAS Tracking'],  
    features: ['Ad campaign design & setup', 'Demographic & behavior targeting', 'High-converting creative design', 'Rigorous A/B split testing', 'Clear conversions & ROAS analytics'] 
  }
];

const breadcrumbs = [
  { label: 'Services', href: '/services' }
];

const servicesSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://zentrix-technology.vercel.app/services#webpage",
      "url": "https://zentrix-technology.vercel.app/services",
      "name": "Expert Digital Services | Zentrix Technology",
      "description": "Explore premium digital services offered by Zentrix Technology. We specialize in Website Development, Mobile Apps, Custom Software, HMS, SEO, and Meta Ads in Salem and Tamil Nadu."
    },
    {
      "@type": "ItemList",
      "@id": "https://zentrix-technology.vercel.app/services#itemlist",
      "name": "Zentrix Technology Service Offerings",
      "itemListElement": services.map((s, idx) => ({
        "@type": "Service",
        "position": idx + 1,
        "name": s.title + " in Salem, Tamil Nadu",
        "description": s.desc,
        "provider": {
          "@id": "https://zentrix-technology.vercel.app/#localbusiness"
        }
      }))
    }
  ]
};
---
<Layout title="Premium Services | Website & Software Company in Salem" description="Discover professional digital solutions: Web development, Mobile apps, Custom Software development, Hospital Management Software (HMS), SEO and Meta Ads services in Salem, Tamil Nadu." breadcrumbs={breadcrumbs} schema={servicesSchema}>

<!-- Hero -->
<section class="svc-hero" aria-labelledby="svc-h1">
  <div class="blob blob-violet" style="width:700px;height:700px;top:-200px;right:-200px;opacity:0.5;" aria-hidden="true"></div>
  <div class="blob blob-cyan" style="width:500px;height:500px;bottom:-100px;left:-150px;opacity:0.35;" aria-hidden="true"></div>
  <div class="bg-grid" style="position:absolute;inset:0;pointer-events:none;" aria-hidden="true"></div>

  <div class="container-z stagger-group" style="position:relative;z-index:2;text-align:center;">
    <h1 id="svc-h1" class="stagger-child" style="font-size:var(--display);font-weight:800;letter-spacing:-0.05em;line-height:1.03;margin:1.25rem 0 1.5rem;">
      Our <span class="text-gradient">Services</span>
    </h1>
    <p class="stagger-child" style="font-size:1.125rem;color:var(--t2);max-width:600px;margin:0 auto 2.5rem;line-height:1.8;">
      Seven specialized technology and marketing areas engineered to help local and global businesses grow online.
    </p>
    <div class="stagger-child" style="display:flex;justify-content:center;gap:1rem;flex-wrap:wrap;">
      <a href="/contact" class="btn-primary" id="svc-hero-cta">Get Free Consultation</a>
      <a href="#web" class="btn-secondary" id="svc-explore-link">Explore Services</a>
    </div>
  </div>
</section>

<!-- Services -->
{services.map((s, i) => (
  <section id={s.id} class={`service-section ${i % 2 === 1 ? 'service-section-alt' : ''}`} aria-labelledby={`svc-${s.id}-h`}>
    <div class="container-z service-split">

      <!-- Text -->
      <div class={`service-text ${i % 2 === 0 ? 'reveal-left' : 'reveal-right'}`}>
        <div class="svc-num-tag" style={`color:${s.color};`}>
          <span style={`width:20px;height:1px;background:${s.color};opacity:0.5;display:inline-block;`}></span>
          {s.num} — {s.title}
        </div>
        <h2 id={`svc-${s.id}-h`} class="service-title">{s.title}</h2>
        <p class="service-desc">{s.desc}</p>

        <ul class="feature-list">
          {s.features.map(f => (
            <li class="feature-item">
              <span class="feat-check" style={`color:${s.color};border-color:${s.colorBorder};background:${s.colorDim};`}>✓</span>
              {f}
            </li>
          ))}
        </ul>

        <div class="svc-tags-wrap" style="margin-top: 1.5rem; display: flex; flex-wrap: wrap; gap: 0.5rem;">
          {s.tags.map(t => <span class="tech-tag" style={`color:${s.color};border-color:${s.colorBorder};background:${s.colorDim};`}>{t}</span>)}
        </div>

        <div style="margin-top: 2rem; display: flex; gap: 1rem;">
          <a href="/contact" class="btn-primary" id={`svc-${s.id}-cta`}>
            Get Started
          </a>
          {s.id === 'hms' && (
            <a href="/contact?ref=hms-demo" class="btn-secondary">
              Book a Demo
            </a>
          )}
        </div>
      </div>

      <!-- Visual -->
      <div class={`service-visual ${i % 2 === 0 ? 'reveal-right' : 'reveal-left'}`}>
        <div class="svc-card" style={`border-color:${s.colorBorder};`}>
          <div class="svc-card-top" style={`background:${s.colorDim};border-bottom-color:${s.colorBorder}15;`}>
            <span class="svc-emoji">{s.emoji}</span>
            <div>
              <p class="svc-card-num" style={`color:${s.color};`}>{s.num}</p>
              <h3 class="svc-card-title">{s.title}</h3>
            </div>
          </div>
          <div class="svc-card-body">
            <ul class="feature-list" style="margin-top:0;">
              {s.features.map(f => (
                <li class="feature-item" style="font-size:0.85rem;">
                  <span class="feat-check" style={`color:${s.color};border-color:${s.colorBorder};background:${s.colorDim};width:16px;height:16px;font-size:0.5rem;`}>✓</span>
                  {f}
                </li>
              ))}
            </ul>
          </div>
          <div class="svc-card-glow" style={`background:radial-gradient(circle at 50% 100%, ${s.colorDim} 0%, transparent 70%);`}></div>
        </div>
      </div>
    </div>
  </section>
))}

<!-- CTA -->
<section class="section-pad" style="background:var(--void);text-align:center;position:relative;overflow:hidden;" aria-labelledby="svc-cta-h">
  <div class="blob blob-violet" style="width:600px;height:600px;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0.45;" aria-hidden="true"></div>
  <div class="cta-glow" aria-hidden="true"></div>
  <div class="container-z stagger-group" style="position:relative;z-index:1;">
    <p class="label stagger-child" style="justify-content:center;">Next Step</p>
    <h2 id="svc-cta-h" class="stagger-child" style="font-size:var(--h1);font-weight:800;letter-spacing:-0.04em;max-width:16ch;margin:1rem auto 1.5rem;">
      Let's Build Your Digital <span class="text-gradient">Success Story</span>
    </h2>
    <div class="stagger-child" style="display:flex;justify-content:center;flex-wrap:wrap;gap:1rem;">
      <a href="/contact" class="btn-primary" id="svc-final-cta">Start Your Project</a>
      <a href="tel:+916380957425" class="btn-secondary" id="svc-call">📞 Call +91 63809 57425</a>
    </div>
  </div>
</section>

</Layout>

<style>
.svc-hero {
  position: relative; overflow: hidden;
  padding: clamp(7rem,13vw,10rem) 0 clamp(5rem,9vw,8rem);
}
.service-section {
  padding: clamp(5rem, 9vw, 9rem) 0;
  position: relative;
}
.service-section-alt { background: var(--surface); }
.service-split {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3.5rem;
  align-items: center;
}
@media (min-width: 1024px) {
  .service-split { grid-template-columns: 1fr 1fr; gap: 5rem; }
  .service-section-alt .service-text { order: 2; }
  .service-section-alt .service-visual { order: 1; }
}
.svc-num-tag {
  font-family: 'Space Mono', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  display: flex; align-items: center; gap: 0.5rem;
  margin-bottom: 1.25rem;
}
.service-title {
  font-size: var(--h2);
  font-weight: 800;
  letter-spacing: -0.04em;
  margin-bottom: 1.25rem;
  line-height: 1.07;
}
.service-desc {
  font-size: 1rem;
  color: var(--t2);
  line-height: 1.8;
  margin-bottom: 2rem;
  max-width: 460px;
}
.feature-list { list-style: none; display: flex; flex-direction: column; gap: 0.625rem; }
.feature-item {
  display: flex; align-items: center; gap: 0.875rem;
  font-size: 0.9375rem; color: var(--t2);
}
.feat-check {
  width: 22px; height: 22px; border-radius: 50%;
  border: 1px solid; display: flex; align-items: center; justify-content: center;
  font-size: 0.6rem; font-weight: 800; flex-shrink: 0;
}
.svc-card {
  background: var(--surface);
  border: 1px solid;
  border-radius: 20px;
  overflow: hidden;
  position: relative;
  box-shadow: 0 40px 80px rgba(0,0,0,0.35);
}
.svc-card-top {
  display: flex; align-items: center; gap: 1.25rem;
  padding: 1.75rem;
  border-bottom: 1px solid;
}
.svc-emoji { font-size: 2.5rem; }
.svc-card-num {
  font-family: 'Space Mono', monospace;
  font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase;
  margin-bottom: 0.25rem;
}
.svc-card-title {
  font-size: 1.25rem; font-weight: 800; letter-spacing: -0.03em; color: var(--t1);
}
.svc-card-body { padding: 1.75rem; }
.svc-tags-wrap { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.svc-card-glow { position: absolute; inset: 0; pointer-events: none; }
.cta-glow {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 600px; height: 300px;
  background: var(--gradient-glow);
  filter: blur(120px);
  border-radius: 50%; opacity: 0.3;
  pointer-events: none;
}
.section-pad { padding: var(--section-y) 0; }
</style>
