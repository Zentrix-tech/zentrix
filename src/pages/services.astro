---
import Layout from '../layouts/Layout.astro';

const services = [
  { id:'web',  num:'01', emoji:'🖥️', title:'Web Development',        color:'var(--v4)', colorDim:'var(--v-dim)',  colorBorder:'var(--v-border)',  desc:'High-performance websites built for Core Web Vitals, SEO, and maximum conversion. From marketing pages to complex SaaS platforms.',       tags:['React','Next.js','Astro','TypeScript','PostgreSQL'],  features:['Custom design & development','E-commerce & CMS','Performance optimization','SEO-first architecture','Web App development'] },
  { id:'app',  num:'02', emoji:'📱', title:'App Development',         color:'var(--v5)', colorDim:'var(--v-dim)',   colorBorder:'var(--v-border)',   desc:'Cross-platform mobile apps with native performance. From initial wireframes to both App Stores on time and on budget.',             tags:['React Native','Flutter','iOS','Android','Firebase'],  features:['iOS & Android apps','Cross-platform development','UI/UX design','Backend API integration','App Store submission'] },
  { id:'mkt',  num:'03', emoji:'📣', title:'Digital Marketing',       color:'var(--v3)', colorDim:'var(--v-dim)',  colorBorder:'var(--v-border)',  desc:'Full-service digital marketing that grows your brand online. Content strategy, email automation, and social media management.',          tags:['Content Strategy','Email Marketing','Social Media','Analytics'], features:['Content marketing strategy','Email campaign automation','Social media management','Brand positioning','Conversion funnel optimization'] },
  { id:'meta', num:'04', emoji:'🎯', title:'Meta Ads Management',     color:'var(--v4)', colorDim:'var(--v-dim)',  colorBorder:'var(--v-border)',  desc:'Expert Facebook & Instagram advertising that generates qualified leads and maximizes your ad spend with precision targeting.',        tags:['Facebook Ads','Instagram Ads','Retargeting','ROAS'],  features:['Campaign strategy & setup','Audience research','Creative design','A/B testing','Performance reporting'] },
  { id:'seo',  num:'05', emoji:'🔍', title:'SEO Optimization',        color:'var(--v5)', colorDim:'var(--v-dim)',  colorBorder:'var(--v-border)',  desc:'Dominate search rankings and drive organic traffic that actually converts. Technical SEO, content strategy, and link building.',       tags:['Technical SEO','Content SEO','Link Building','Local SEO'], features:['Technical audit & fixes','Keyword research','On-page optimization','Link building','Monthly analytics reporting'] },
];
---
<Layout title="Services" description="Zentrix Technology services — Web Development, App Development, Digital Marketing, Meta Ads & SEO Optimization. Digital solutions for real growth.">

<!-- Hero -->
<section class="svc-hero" aria-labelledby="svc-h1">
  <div class="blob blob-violet" style="width:700px;height:700px;top:-200px;right:-200px;opacity:0.5;" aria-hidden="true"></div>
  <div class="blob blob-cyan" style="width:500px;height:500px;bottom:-100px;left:-150px;opacity:0.35;" aria-hidden="true"></div>
  <div class="bg-grid" style="position:absolute;inset:0;pointer-events:none;" aria-hidden="true"></div>

  <div class="container-z stagger-group" style="position:relative;z-index:2;text-align:center;">
    <p class="label stagger-child" style="justify-content:center;">What We Build</p>
    <h1 id="svc-h1" class="stagger-child" style="font-size:var(--display);font-weight:800;letter-spacing:-0.05em;line-height:1.03;margin:1.25rem 0 1.5rem;">
      Our <span class="text-gradient">Services</span>
    </h1>
    <p class="stagger-child" style="font-size:1.125rem;color:var(--t2);max-width:500px;margin:0 auto 2.5rem;line-height:1.8;">
      Five specialized areas, one mission — help your business grow online.
    </p>
    <div class="stagger-child" style="display:flex;justify-content:center;gap:1rem;flex-wrap:wrap;">
      <a href="/contact" class="btn-primary" id="svc-hero-cta">Get Started →</a>
      <a href="#web" class="btn-secondary" id="svc-explore-link">Explore All →</a>
    </div>
  </div>
</section>

<!-- Services -->
{services.map((s, i) => (
  <section id={s.id} class={`service-section ${i % 2 === 1 ? 'service-section-alt' : ''}`} aria-labelledby={`svc-${s.id}-h`}>
    <div class="container-z service-split">

      <!-- Text -->
      <div class={`service-text ${i % 2 === 0 ? 'reveal-left' : 'reveal-right'}`}>
        <div class="svc-num-tag" style={`color:${s.color};`}>
          <span style={`width:20px;height:1px;background:${s.color};opacity:0.5;display:inline-block;`}></span>
          {s.num} — {s.title}
        </div>
        <h2 id={`svc-${s.id}-h`} class="service-title">{s.title}</h2>
        <p class="service-desc">{s.desc}</p>

        <ul class="feature-list">
          {s.features.map(f => (
            <li class="feature-item">
              <span class="feat-check" style={`color:${s.color};border-color:${s.colorBorder};background:${s.colorDim};`}>✓</span>
              {f}
            </li>
          ))}
        </ul>

        <a href="/contact" class="btn-primary" id={`svc-${s.id}-cta`} style="margin-top:2rem;">
          Get Started →
        </a>
      </div>

      <!-- Visual -->
      <div class={`service-visual ${i % 2 === 0 ? 'reveal-right' : 'reveal-left'}`}>
        <div class="svc-card" style={`border-color:${s.colorBorder};`}>
          <div class="svc-card-top" style={`background:${s.colorDim};border-bottom-color:${s.colorBorder}15;`}>
            <span class="svc-emoji">{s.emoji}</span>
            <div>
              <p class="svc-card-num" style={`color:${s.color};`}>{s.num}</p>
              <h3 class="svc-card-title">{s.title}</h3>
            </div>
          </div>
          <div class="svc-card-body">
            <ul class="feature-list" style="margin-top:0;">
              {s.features.map(f => (
                <li class="feature-item" style="font-size:0.85rem;">
                  <span class="feat-check" style={`color:${s.color};border-color:${s.colorBorder};background:${s.colorDim};width:16px;height:16px;font-size:0.5rem;`}>✓</span>
                  {f}
                </li>
              ))}
            </ul>
          </div>
          <div class="svc-card-glow" style={`background:radial-gradient(circle at 50% 100%, ${s.colorDim} 0%, transparent 70%);`}></div>
        </div>
      </div>
    </div>
  </section>
))}

<!-- CTA -->
<section class="section-pad" style="background:var(--void);text-align:center;position:relative;overflow:hidden;" aria-labelledby="svc-cta-h">
  <div class="blob blob-violet" style="width:600px;height:600px;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0.45;" aria-hidden="true"></div>
  <div class="cta-glow" aria-hidden="true"></div>
  <div class="container-z stagger-group" style="position:relative;z-index:1;">
    <p class="label stagger-child" style="justify-content:center;">Next Step</p>
    <h2 id="svc-cta-h" class="stagger-child" style="font-size:var(--h1);font-weight:800;letter-spacing:-0.04em;max-width:16ch;margin:1rem auto 1.5rem;">
      Let's Build Your Digital <span class="text-gradient">Success Story</span>
    </h2>
    <div class="stagger-child" style="display:flex;justify-content:center;flex-wrap:wrap;gap:1rem;">
      <a href="/contact" class="btn-primary" id="svc-final-cta">Start a Project →</a>
      <a href="tel:6380957425" class="btn-secondary" id="svc-call">📞 6380957425</a>
    </div>
  </div>
</section>

</Layout>

<style>
.svc-hero {
  position: relative; overflow: hidden;
  padding: clamp(7rem,13vw,10rem) 0 clamp(5rem,9vw,8rem);
}
.service-section {
  padding: clamp(5rem, 9vw, 9rem) 0;
  position: relative;
}
.service-section-alt { background: var(--surface); }
.service-split {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3.5rem;
  align-items: center;
}
@media (min-width: 1024px) {
  .service-split { grid-template-columns: 1fr 1fr; gap: 5rem; }
  .service-section-alt .service-text { order: 2; }
  .service-section-alt .service-visual { order: 1; }
}
.svc-num-tag {
  font-family: 'Space Mono', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  display: flex; align-items: center; gap: 0.5rem;
  margin-bottom: 1.25rem;
}
.service-title {
  font-size: var(--h2);
  font-weight: 800;
  letter-spacing: -0.04em;
  margin-bottom: 1.25rem;
  line-height: 1.07;
}
.service-desc {
  font-size: 1rem;
  color: var(--t2);
  line-height: 1.8;
  margin-bottom: 2rem;
  max-width: 460px;
}
.feature-list { list-style: none; display: flex; flex-direction: column; gap: 0.625rem; }
.feature-item {
  display: flex; align-items: center; gap: 0.875rem;
  font-size: 0.9375rem; color: var(--t2);
}
.feat-check {
  width: 22px; height: 22px; border-radius: 50%;
  border: 1px solid; display: flex; align-items: center; justify-content: center;
  font-size: 0.6rem; font-weight: 800; flex-shrink: 0;
}
.svc-card {
  background: var(--surface);
  border: 1px solid;
  border-radius: 20px;
  overflow: hidden;
  position: relative;
  box-shadow: 0 40px 80px rgba(0,0,0,0.35);
}
.svc-card-top {
  display: flex; align-items: center; gap: 1.25rem;
  padding: 1.75rem;
  border-bottom: 1px solid;
}
.svc-emoji { font-size: 2.5rem; }
.svc-card-num {
  font-family: 'Space Mono', monospace;
  font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase;
  margin-bottom: 0.25rem;
}
.svc-card-title {
  font-size: 1.25rem; font-weight: 800; letter-spacing: -0.03em; color: var(--t1);
}
.svc-card-body { padding: 1.75rem; }
.svc-tags-wrap { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.svc-card-glow { position: absolute; inset: 0; pointer-events: none; }
.cta-glow {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 600px; height: 300px;
  background: var(--gradient-glow);
  filter: blur(120px);
  border-radius: 50%; opacity: 0.3;
  pointer-events: none;
}
.section-pad { padding: var(--section-y) 0; }
</style>
