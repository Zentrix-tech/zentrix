---
import Layout from '../layouts/Layout.astro';
import { Target, Compass, Code2, Cpu, Globe, Database, Briefcase, Zap, Smartphone } from 'lucide-react';

const techStack = [
  { name: "React", category: "Frontend" },
  { name: "Next.js", category: "Framework" },
  { name: "Astro", category: "Performance" },
  { name: "Node.js", category: "Backend" },
  { name: "Flutter", category: "Mobile" },
  { name: "AWS", category: "Cloud" },
  { name: "TypeScript", category: "Language" },
  { name: "PostgreSQL", category: "Database" }
];
---

<Layout title="About">
  
  <section class="pt-60 pb-32 relative overflow-hidden">
     <div class="absolute inset-0 topographic-lines opacity-10 pointer-events-none"></div>
     <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-4xl section-reveal">
           <span class="text-[10px] font-mono tracking-[0.5em] text-white uppercase mb-8 block">Our DNA</span>
           <h1 class="text-7xl md:text-9xl font-serif italic text-white mb-10 leading-[0.85] reveal-up">Engineering <br/><span class="text-white not-italic">Excellence.</span></h1>
           <p class="text-xl text-white font-mono leading-relaxed max-w-2xl reveal-up">
              Zentrix Technology is a specialized engineering lab focused on building high-performance digital platforms for forward-thinking businesses.
           </p>
        </div>
     </div>
  </section>

  <!-- Mission / Vision -->
  <section class="pb-60">
     <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
           <div class="reveal-on-scroll">
              <div class="flex items-center gap-6 mb-12">
                 <div class="w-12 h-12 border border-white text-white rounded-full flex items-center justify-center">
                    <Target className="w-5 h-5" />
                 </div>
                 <h2 class="text-4xl font-serif italic text-white tracking-tight">The Mission</h2>
              </div>
              <p class="text-lg text-white font-mono leading-relaxed mb-10">
                 We bridge the gap between engineering complexity and user-centric design. Our mission is to empower growth-stage companies with the same technology stacks used by tech giants, optimized for agility and scale.
              </p>
              <p class="text-white font-mono leading-relaxed">
                 Founded on the principles of performance-first engineering, Zentrix functions as a strategic technical partner rather than a traditional service provider.
              </p>
           </div>
           
           <div class="relative rounded-[1rem] overflow-hidden aspect-square bg-white/10 border border-white/20 reveal-on-scroll group">
              <div class="absolute inset-0 flex items-center justify-center overflow-hidden">
                 <div class="text-[10vw] font-serif italic text-white opacity-10 uppercase select-none tracking-tighter group-hover:scale-110 group-hover:opacity-20 transition-transform duration-[3s]">THE ETHOS</div>
              </div>
           </div>
        </div>
     </div>
  </section>

  <!-- Tech Stack Grid -->
  <section class="py-40 border-y border-white/10 relative overflow-hidden">
     <div class="absolute inset-0 topographic-lines opacity-10 pointer-events-none"></div>
     <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-2xl mb-24 reveal-on-scroll">
           <span class="text-[10px] font-mono tracking-[0.5em] text-white uppercase mb-6 block">Capabilities</span>
           <h2 class="text-5xl md:text-7xl font-serif text-white tracking-tighter mb-8 leading-none">The Vertical <br/><span class="italic text-white">Protocol.</span></h2>
           <p class="text-white font-mono max-w-lg">We leverage a curated, battle-tested stack to ensure maximum performance, security, and developer velocity.</p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-1">
           {techStack.map((tech) => (
              <div class="p-12 border border-white/10 hover:bg-white/10 transition-all duration-700 reveal-on-scroll group">
                 <div class="text-[9px] font-mono tracking-[0.3em] text-white uppercase mb-6 opacity-50 group-hover:opacity-100 transition-all">
                    {tech.category}
                 </div>
                 <h3 class="text-xl font-serif italic text-white">{tech.name}</h3>
              </div>
           ))}
        </div>
     </div>
  </section>

  <!-- Values / Culture -->
  <section class="py-60">
     <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-16 text-center">
           <div class="reveal-on-scroll">
              <div class="w-16 h-16 mx-auto border border-white text-white rounded-full flex items-center justify-center mb-10">
                 <Zap className="w-6 h-6" />
              </div>
              <h3 class="text-lg font-serif italic text-white mb-6 uppercase tracking-wider">Performance</h3>
              <p class="text-xs font-mono text-white leading-relaxed max-w-[250px] mx-auto">Every line of code is optimized for milliseconds, ensuring the best user experience.</p>
           </div>
           <div class="reveal-on-scroll" style="transition-delay: 0.1s">
              <div class="w-16 h-16 mx-auto border border-white text-white rounded-full flex items-center justify-center mb-10">
                 <Globe className="w-6 h-6" />
              </div>
              <h3 class="text-lg font-serif italic text-white mb-6 uppercase tracking-wider">Scale</h3>
              <p class="text-xs font-mono text-white leading-relaxed max-w-[250px] mx-auto">Architectures built to handle millions of requests without breaking a sweat.</p>
           </div>
           <div class="reveal-on-scroll" style="transition-delay: 0.2s">
              <div class="w-16 h-16 mx-auto border border-white text-white rounded-full flex items-center justify-center mb-10">
                 <Briefcase className="w-6 h-6" />
              </div>
              <h3 class="text-lg font-serif italic text-white mb-6 uppercase tracking-wider">Strategy</h3>
              <p class="text-xs font-mono text-white leading-relaxed max-w-[250px] mx-auto">We don't just build; we integrate deeply with your business operations.</p>
           </div>
        </div>
     </div>
  </section>

  <!-- CTA -->
  <section class="py-60 mx-6 mb-32 rounded-[1rem] relative overflow-hidden border border-white/10">
      <div class="absolute inset-0 topographic-lines opacity-10 pointer-events-none"></div>
      <div class="container mx-auto px-6 text-center max-w-4xl relative z-10">
         <h2 class="text-6xl md:text-8xl font-serif italic text-white tracking-tight mb-16 leading-none">The Future <br/><span class="not-italic text-white">is engineered.</span></h2>
         <a href="/contact" class="inline-flex items-center justify-center px-16 py-8 bg-white text-black rounded-full text-[11px] font-mono tracking-[0.6em] uppercase hover:scale-105 transition-all duration-700">
            Start Collaboration
         </a>
      </div>
  </section>

</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    // Entrance Animations
    gsap.from('.reveal-up', {
      y: 100,
      opacity: 0,
      duration: 1.5,
      stagger: 0.2,
      ease: 'expo.out'
    });

    // Scroll Revelations
    const reveals = document.querySelectorAll('.reveal-on-scroll');
    reveals.forEach(el => {
      gsap.from(el, {
        y: 60,
        opacity: 0,
        duration: 1.2,
        ease: 'expo.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          toggleActions: 'play none none none'
        }
      });
    });
  });

  document.addEventListener('barba_after', () => {
     ScrollTrigger.refresh();
  });
</script>
