---
import Layout from '../../layouts/Layout.astro';

const posts = Object.values(import.meta.glob('../../blog-posts/*.md', { eager: true })) as any[];
const sortedPosts = posts.sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const categories = [
  'All',
  'Website Development',
  'Digital Marketing',
  'SEO',
  'AI Technology',
  'Healthcare Technology',
  'Hospital Management Systems',
  'Meta Ads'
];

const breadcrumbs = [
  { label: 'Blog', href: '/blog' }
];

const blogPageSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "@id": "https://zentrix-technology.vercel.app/blog#blog",
  "name": "Zentrix Technology Blog",
  "url": "https://zentrix-technology.vercel.app/blog",
  "description": "Insights, guides, and updates on website development, software engineering, digital marketing, local SEO, and healthcare technology.",
  "publisher": {
    "@id": "https://zentrix-technology.vercel.app/#localbusiness"
  }
};
---
<Layout title="Blog | Digital Insights & Technology Guides" description="Read our latest insights on Website Development, Custom Software systems, Local SEO, and Digital Marketing strategies by Zentrix Technology Salem." breadcrumbs={breadcrumbs} schema={blogPageSchema}>

<section class="blog-hero" aria-labelledby="blog-h1">
  <div class="blob blob-violet" style="width:700px;height:700px;top:-200px;left:-150px;opacity:0.45;" aria-hidden="true"></div>
  <div class="blob blob-cyan" style="width:500px;height:500px;bottom:-100px;right:-100px;opacity:0.3;" aria-hidden="true"></div>
  <div class="bg-grid" style="position:absolute;inset:0;pointer-events:none;" aria-hidden="true"></div>

  <div class="container-z stagger-group" style="position:relative;z-index:2;text-align:center;">
    <h1 id="blog-h1" class="stagger-child" style="font-size:var(--display);font-weight:800;letter-spacing:-0.05em;line-height:1.03;margin:1.25rem 0 1.5rem;">
      Our <span class="text-gradient">Blog</span>
    </h1>
    <p class="stagger-child" style="font-size:1.125rem;color:var(--t2);max-width:500px;margin:0 auto 2.5rem;line-height:1.8;">
      Expert advice, trend reports, and tips on digital marketing, local SEO, custom software, and hospital systems.
    </p>
  </div>
</section>

<!-- Category Filters -->
<section style="padding-bottom: 2rem; position: relative; z-index: 10;">
  <div class="container-z">
    <div class="category-filters reveal" style="display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; margin-bottom: 3rem;">
      {categories.map((cat, idx) => (
        <button 
          class={`cat-filter-btn ${idx === 0 ? 'active' : ''}`}
          data-category={cat}
          style="cursor: pointer;"
        >
          {cat}
        </button>
      ))}
    </div>
  </div>
</section>

<!-- Posts Grid -->
<section style="padding-bottom: clamp(5rem, 9vw, 9rem);" aria-label="Blog posts list">
  <div class="container-z">
    <div class="blog-grid" style="display: grid; grid-template-columns: 1fr; gap: 2.5rem;">
      {sortedPosts.map((p, idx) => (
        <article class="blog-card card reveal" data-category={p.frontmatter.category} style="display: flex; flex-direction: column; gap: 1.5rem; transition: all 300ms var(--expo);">
          <div class="blog-img-wrap" style="position: relative; aspect-ratio: 16/9; border-radius: 14px; overflow: hidden; border: 1px solid var(--b1); background: var(--surface);">
            <img src={p.frontmatter.image} alt={p.frontmatter.title} style="width: 100%; height: 100%; object-fit: cover; transition: transform 500ms var(--expo);" class="blog-img" loading="lazy" />
            <div class="blog-cat-tag" style="position: absolute; top: 1rem; left: 1rem; font-family: 'Space Mono', monospace; font-size: 0.65rem; background: var(--v-dim); color: var(--v4); border: 1px solid var(--v-border); padding: 0.35rem 0.85rem; border-radius: 100px;">
              {p.frontmatter.category}
            </div>
          </div>
          
          <div class="blog-content" style="display: flex; flex-direction: column; gap: 0.75rem;">
            <p style="font-family: 'Space Mono', monospace; font-size: 0.72rem; color: var(--t3);">
              {p.frontmatter.date} · By {p.frontmatter.author}
            </p>
            <h2 class="blog-title" style="font-size: 1.5rem; font-weight: 800; color: var(--t1); margin-top: 0.25rem;">
              <a href={`/blog/${p.frontmatter.slug}`} style="transition: color 200ms;" class="blog-title-link">
                {p.frontmatter.title}
              </a>
            </h2>
            <p style="color: var(--t2); font-size: 0.95rem; line-height: 1.7; margin-bottom: 1rem;">
              {p.frontmatter.description}
            </p>
            <a href={`/blog/${p.frontmatter.slug}`} class="btn-ghost" style="width: fit-content;">
              Read Article →
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Empty state -->
    <div id="no-posts-message" class="card" style="display: none; text-align: center; padding: 4rem 2rem;">
      <p style="font-size: 1.125rem; color: var(--t2);">No articles found in this category. We are working on adding new posts soon!</p>
    </div>
  </div>
</section>

</Layout>

<style>
.blog-hero {
  position: relative; overflow: hidden;
  padding: clamp(7rem,13vw,10rem) 0 clamp(3rem,6vw,4rem);
}
.blog-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
}
@media (min-width: 768px) {
  .blog-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (min-width: 1024px) {
  .blog-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* Category buttons */
.cat-filter-btn {
  font-family: 'Space Mono', monospace;
  font-size: 0.75rem;
  color: var(--t3);
  background: var(--surface);
  border: 1px solid var(--b1);
  padding: 0.5rem 1.125rem;
  border-radius: 100px;
  transition: all 250ms var(--expo);
}
.cat-filter-btn:hover {
  color: var(--t1);
  border-color: var(--b3);
}
.cat-filter-btn.active {
  color: var(--t1);
  background: var(--v-dim);
  border-color: var(--v-border);
  box-shadow: 0 0 15px rgba(124,58,237,0.15);
}

/* Hover effects */
.blog-card:hover .blog-img {
  transform: scale(1.05);
}
.blog-title-link:hover {
  color: var(--v5) !important;
}
</style>

<script>
  const initFilters = () => {
    const buttons = document.querySelectorAll('.cat-filter-btn');
    const cards = document.querySelectorAll('.blog-card');
    const noPosts = document.getElementById('no-posts-message');

    if (buttons.length === 0) return;

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = (btn as HTMLElement).dataset['category'] ?? 'All';

        // Set active button
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Filter cards
        let visibleCount = 0;
        cards.forEach(card => {
          const cardCat = (card as HTMLElement).dataset['category'];
          if (cat === 'All' || cardCat === cat) {
            (card as HTMLElement).style.display = 'flex';
            visibleCount++;
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });

        // Show/hide empty state
        if (noPosts) {
          noPosts.style.display = visibleCount === 0 ? 'block' : 'none';
        }
      });
    });
  };

  document.addEventListener('astro:page-load', initFilters);
</script>
