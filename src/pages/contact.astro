---
import Layout from "../layouts/Layout.astro";

const breadcrumbs = [
  { label: 'Contact', href: '/contact' }
];

const contactSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://zentrix-technology.vercel.app/contact#webpage",
      "url": "https://zentrix-technology.vercel.app/contact",
      "name": "Contact Zentrix Technology | Web & Software Company Salem",
      "description": "Get in touch with Zentrix Technology. Start your digital development project today with our expert team in Salem."
    }
  ]
};
---

<Layout
  title="Contact Us | Website & Software Company in Salem"
  description="Connect with Zentrix Technology, the trusted web development and custom software agency in Salem, Tamil Nadu. Get a free consultation or request a quote."
  breadcrumbs={breadcrumbs}
  schema={contactSchema}
>
  <!-- Hero -->
  <section class="contact-hero" aria-labelledby="contact-h1">
    <div
      class="blob blob-violet"
      style="width:700px;height:700px;top:-200px;right:-150px;opacity:0.45;"
      aria-hidden="true"
    >
    </div>
    <div
      class="blob blob-cyan"
      style="width:500px;height:500px;bottom:-100px;left:-100px;opacity:0.3;"
      aria-hidden="true"
    >
    </div>
    <div
      class="bg-grid"
      style="position:absolute;inset:0;pointer-events:none;"
      aria-hidden="true"
    >
    </div>

    <div
      class="container-z stagger-group"
      style="position:relative;z-index:2;text-align:center;"
    >
      <p class="label stagger-child" style="justify-content:center;">
        Get In Touch
      </p>
      <h1
        id="contact-h1"
        class="stagger-child"
        style="font-size:var(--display);font-weight:800;letter-spacing:-0.05em;line-height:1.03;margin:1.25rem 0 1.5rem;"
      >
        Let's Start a <span class="text-gradient">Project</span>
      </h1>
      <p
        class="stagger-child"
        style="font-size:1.125rem;color:var(--t2);max-width:500px;margin:0 auto;line-height:1.8;"
      >
        Tell us about your business goals. Our team is ready to build the
        digital solution that gets you there.
      </p>
    </div>
  </section>

  <!-- Contact Form / Details Split -->
  <section
    style="padding:clamp(4rem,8vw,7rem) 0;"
    aria-label="Contact details and form"
  >
    <div class="container-z contact-split">
      <!-- Contact Info -->
      <div class="reveal-left">
        <div
          class="card glass-glow"
          style="height:100%;display:flex;flex-direction:column;justify-content:center;padding:clamp(2rem,4vw,4rem);"
        >
          <h2
            style="font-size:var(--h2);font-weight:800;letter-spacing:-0.03em;margin-bottom:1rem;"
          >
            Contact Info
          </h2>
          <p style="color:var(--t2);margin-bottom:3rem;max-width:320px;">
            Reach out directly or use the form. We aim to respond to all
            inquiries within 24 hours.
          </p>

          <div style="display:flex;flex-direction:column;gap:2rem;">
            <!-- Phone -->
            <a href="tel:+916380957425" class="contact-info-link">
              <span
                class="contact-icon"
                style="background:var(--v-dim);border-color:var(--v-border);"
                >📞</span
              >
              <div>
                <p
                  style="font-family:'Space Mono',monospace;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--t3);"
                >
                  Give us a call
                </p>
                <p style="font-size:1.125rem;color:var(--t1);font-weight:700;">
                  +91 63809 57425
                </p>
              </div>
            </a>

            <!-- Email -->
            <a href="mailto:zentrixtech01@gmail.com" class="contact-info-link">
              <span
                class="contact-icon"
                style="background:var(--v-dim);border-color:var(--v-border);"
                >✉️</span
              >
              <div>
                <p
                  style="font-family:'Space Mono',monospace;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--t3);"
                >
                  Send an email
                </p>
                <p
                  style="font-size:1rem;color:var(--t1);font-weight:700;word-break:break-all;"
                >
                  zentrixtech01@gmail.com
                </p>
              </div>
            </a>

            <!-- HQ -->
            <div class="contact-info-link" style="cursor:default;opacity:1;">
              <span
                class="contact-icon"
                style="background:var(--v-dim);border-color:var(--v-border);"
                >📍</span
              >
              <div>
                <p
                  style="font-family:'Space Mono',monospace;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--t3);"
                >
                  Location
                </p>
                <p style="font-size:1rem;color:var(--t1);font-weight:700;">
                  Fairlands, Salem, Tamil Nadu, India
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="reveal-right">
        <div class="card" style="padding:clamp(2rem,4vw,4rem);">
          <form
            id="contact-form"
            class="c-form"
            data-netlify="true"
            name="contact"
          >
            <div class="form-row">
              <div class="form-group">
                <label for="name" class="form-label"
                  >Full Name <span class="req">*</span></label
                >
                <input
                  type="text"
                  id="name"
                  name="name"
                  class="form-field"
                  placeholder="John Doe"
                  required
                />
              </div>
              <div class="form-group">
                <label for="email" class="form-label"
                  >Email Address <span class="req">*</span></label
                >
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="form-field"
                  placeholder="john@company.com"
                  required
                />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="phone" class="form-label">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="form-field"
                  placeholder="+1 (555) 000-0000"
                />
              </div>
              <div class="form-group">
                <label for="service" class="form-label"
                  >Service Required <span class="req">*</span></label
                >
                <select id="service" name="service" class="form-field" required>
                  <option value="" disabled selected>Select a service...</option
                  >
                  <option value="web">Web Development</option>
                  <option value="app">App Development</option>
                  <option value="marketing">Digital Marketing</option>
                  <option value="meta">Meta Ads Management</option>
                  <option value="seo">SEO Optimization</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label for="message" class="form-label"
                >Project Details <span class="req">*</span></label
              >
              <textarea
                id="message"
                name="message"
                class="form-field"
                rows="4"
                placeholder="Tell us about your goals, timeline, and budget..."
                required></textarea>
            </div>

            <button
              type="submit"
              class="btn-primary"
              style="width:100%;margin-top:1rem;"
            >
              Send Message
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                aria-hidden="true"
                ><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path></svg
              >
            </button>

            <p class="form-note">
              By submitting this form, you agree to our privacy policy and terms
              of service.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(7rem, 13vw, 10rem) 0 clamp(3rem, 6vw, 5rem);
  }
  .contact-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 992px) {
    .contact-split {
      grid-template-columns: 0.85fr 1.15fr;
      gap: 4rem;
    }
  }

  /* ── Contact Info Links ── */
  .contact-info-link {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    transition:
      transform 250ms var(--expo),
      opacity 200ms;
  }
  .contact-info-link:hover {
    transform: translateX(8px);
  }
  .contact-icon {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    flex-shrink: 0;
    transition: transform 300ms var(--spring);
  }
  .contact-info-link:hover .contact-icon {
    transform: scale(1.1);
  }

  /* ── Form Styling ── */
  .c-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 640px) {
    .form-row {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .form-label {
    font-family: "Space Mono", monospace;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--t3);
  }
  .req {
    color: var(--rose);
    margin-left: 2px;
  }
  textarea.form-field {
    resize: vertical;
    min-height: 100px;
  }

  .form-note {
    font-family: "Space Mono", monospace;
    font-size: 0.6rem;
    color: var(--t3);
    text-align: center;
    margin-top: 0.5rem;
    letter-spacing: 0.05em;
  }
</style>

<script>
  // Simple form handling logic
  const form = document.getElementById("contact-form") as HTMLFormElement;
  if (form) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const btn = form.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement;
      const originalText = btn.innerHTML;
      btn.innerHTML = "Sending...";
      btn.style.opacity = "0.7";
      btn.style.pointerEvents = "none";

      // Simulate sending
      setTimeout(() => {
        btn.innerHTML = "✓ Message Sent";
        btn.style.background = "var(--emerald)";
        btn.style.opacity = "1";
        form.reset();

        setTimeout(() => {
          btn.innerHTML = originalText;
          btn.style.background = "";
          btn.style.pointerEvents = "auto";
        }, 3000);
      }, 1200);
    });
  }
</script>
