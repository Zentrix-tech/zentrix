<script>
  /* Accordion Services */
  const initAcc = () => {
    const items = document.querySelectorAll('.svc-item');
    const toggle = (el: Element) => {
      const open = el.classList.contains('open');
      items.forEach(i => { i.classList.remove('open'); i.setAttribute('aria-expanded','false'); });
      if (!open) { el.classList.add('open'); el.setAttribute('aria-expanded','true'); }
    };
    items.forEach(item => {
      item.querySelector('.svc-row-trigger')?.addEventListener('click', () => toggle(item));
      item.addEventListener('keydown', (e: Event) => {
        const ke = e as KeyboardEvent;
        if (ke.key === 'Enter' || ke.key === ' ') { e.preventDefault(); toggle(item); }
      });
    });
    if (items[0]) toggle(items[0]);
  };

  /* FAQ Accordion */
  const initFaq = () => {
    const items = document.querySelectorAll('.faq-item');
    items.forEach(item => {
      const trigger = item.querySelector('.faq-trigger');
      const answerWrapper = item.querySelector('.faq-answer-wrapper') as HTMLElement;
      if (!trigger || !answerWrapper) return;

      const toggleFaq = () => {
        const isOpen = item.classList.contains('open');
        
        // Close all other FAQs
        items.forEach(i => {
          if (i !== item) {
            i.classList.remove('open');
            i.setAttribute('aria-expanded', 'false');
            const wrapper = i.querySelector('.faq-answer-wrapper') as HTMLElement;
            if (wrapper) wrapper.style.maxHeight = '0';
          }
        });

        if (isOpen) {
          item.classList.remove('open');
          item.setAttribute('aria-expanded', 'false');
          answerWrapper.style.maxHeight = '0';
        } else {
          item.classList.add('open');
          item.setAttribute('aria-expanded', 'true');
          answerWrapper.style.maxHeight = answerWrapper.scrollHeight + 'px';
        }
      };

      trigger.addEventListener('click', toggleFaq);
      item.addEventListener('keydown', (e: Event) => {
        const ke = e as KeyboardEvent;
        if (ke.key === 'Enter' || ke.key === ' ') {
          e.preventDefault();
          toggleFaq();
        }
      });
    });
  };

  document.addEventListener('astro:page-load', () => {
    initAcc();
    initFaq();
  });
</script>
