---
import Layout from '../layouts/Layout.astro';

const services = [
  { num: '01', title: 'Website Development', desc: 'Blazing-fast websites and custom web platforms built for SEO, mobile responsiveness, and maximum user conversion in Salem and Tamil Nadu. We construct tailored frontends and robust backends.', tags: ['React', 'Next.js', 'Astro', 'TypeScript'], id: 'web-development' },
  { num: '02', title: 'Mobile App Development', desc: 'Sleek, responsive iOS and Android apps with native-level performance. We manage everything from UI/UX design to App Store optimization.', tags: ['React Native', 'Flutter', 'Swift', 'Kotlin'], id: 'mobile-app' },
  { num: '03', title: 'Custom Software Development', desc: 'Bespoke software platforms, SaaS systems, and customized CRM/ERP tools engineered to match your unique operational workflow and eliminate inefficiencies.', tags: ['Node.js', 'Python', 'PostgreSQL', 'Cloud'], id: 'custom-software' },
  { num: '04', title: 'Hospital Management Software (HMS)', desc: 'Enterprise-grade clinic and hospital automation software. Features include patient registration, billing, pharmacy stock, electronic health records (EHR), and laboratory management.', tags: ['Healthcare Technology', 'Security', 'HIPAA', 'EHR'], id: 'hms-software' },
  { num: '05', title: 'AI Solutions', desc: 'Supercharge your business operations by integrating advanced AI services, LLMs, machine learning models, and automated customer support bots.', tags: ['AI Integration', 'LLMs', 'NLP', 'Data Science'], id: 'ai-solutions' },
  { num: '06', title: 'Digital Marketing', desc: 'Result-oriented marketing strategies targeting local audiences. Content strategy, social media campaigns, brand building, and conversion optimization.', tags: ['Content Strategy', 'Social Media', 'Leads'], id: 'digital-marketing' },
  { num: '07', title: 'SEO Services', desc: 'Dominate organic search queries. Technical audits, schema configuration, backlink building, and local SEO services to put your business at the top of Google rankings.', tags: ['Technical SEO', 'Local SEO', 'Audits'], id: 'seo-services' },
  { num: '08', title: 'Meta Ads Management', desc: 'Precision-targeted Facebook and Instagram ad campaigns optimized for qualified lead generation, retargeting, and maximizing return on ad spend (ROAS).', tags: ['Facebook Ads', 'Instagram Ads', 'ROAS'], id: 'meta-ads' },
  { num: '09', title: 'E-Commerce Development', desc: 'Seamless, secure headless e-commerce architectures. From WooCommerce and Shopify integrations to custom shopping cart platforms designed to convert visitors.', tags: ['Headless commerce', 'Shopify', 'Stripe'], id: 'ecommerce' },
  { num: '10', title: 'Business Automation', desc: 'Remove manual bottlenecks. Connect your legacy platforms, automate customer notifications, email workflows, and sync invoicing systems.', tags: ['APIs', 'Zapier', 'Workflows'], id: 'business-automation' }
];

const whys = [
  { num: '01', icon: '📈', title: 'Increase Visibility', desc: 'Get found everywhere your customers are — search engines, social media, and across every digital touchpoint. We build your presence from the ground up.', stat: '+340%', statLabel: 'Average Traffic Growth' },
  { num: '02', icon: '🎯', title: 'Generate Quality Leads', desc: 'Precision-targeted campaigns that attract genuinely interested prospects ready to buy. No wasted spend, only leads that convert into real customers.', stat: '+180%', statLabel: 'Average Lead Volume' },
  { num: '03', icon: '💰', title: 'Boost Sales & Conversions', desc: 'Turn visitors into loyal customers with optimized funnels, persuasive copy, and strategic calls-to-action powered by data and behavioral insights.', stat: '+95%', statLabel: 'Average Conversion Lift' },
];

const faqs = [
  {
    q: "Which is the best website development company in Salem?",
    a: "Zentrix Technology is recognized as a premier website development company in Salem, Tamil Nadu. We specialize in building responsive, ultra-fast, and SEO-optimized business websites using modern technologies like Next.js, React, and Astro."
  },
  {
    q: "What services does Zentrix Technology offer in Salem?",
    a: "We offer comprehensive digital services including Website Development, Mobile App Development, Custom Software Development, Hospital Management Software (HMS), AI Solutions, Digital Marketing, SEO, and Meta Ads Management."
  },
  {
    q: "How does local SEO benefit Salem-based businesses?",
    a: "Local SEO helps your business rank for queries matching 'near me' or specific location keywords like 'in Salem'. Zentrix Technology configures Google Business Profile listings, implements local schema markup, and generates location-specific keyword copy to drive qualified organic traffic."
  },
  {
    q: "Do you build clinic and hospital management software in Tamil Nadu?",
    a: "Yes! Zentrix Technology provides custom Hospital Management Software (HMS) and clinic management solutions in Tamil Nadu. Our software covers patient management, doctor scheduling, electronic medical records (EMR), billing, inventory, and automated SMS notifications."
  },
  {
    q: "How much does web development or custom software cost?",
    a: "The cost depends on project scope, features, and complexity. We offer a free initial consultation and customized proposals. Reach out via our 'Request a Quote' or 'Get Free Consultation' CTA to receive a tailored estimate."
  }
];

const homepageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://zentrix-technology.vercel.app/#webpage",
      "url": "https://zentrix-technology.vercel.app",
      "name": "Zentrix Technology | Web Development & Software Company in Salem",
      "description": "Zentrix Technology is the leading website development company, mobile app agency, and custom software company in Salem, Tamil Nadu, India. Elevate your local and global visibility.",
      "breadcrumb": {
        "@id": "https://zentrix-technology.vercel.app/#breadcrumb"
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://zentrix-technology.vercel.app/#faq",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---
<Layout title="Web Development Company in Salem & Software Agency" description="Optimize your digital presence with Zentrix Technology, the leading website development company & software agency in Salem, Tamil Nadu. Premium web apps, mobile apps, HMS software, and SEO." schema={homepageSchema}>

  <!-- Load Lottie Player Component -->
  <script is:inline src="https://unpkg.com/@dotlottie/player-component@2.7.12/dist/dotlottie-player.mjs" type="module"></script>

<!-- ════════════════════════════════
     HERO
     ════════════════════════════════ -->
<section class="hero" aria-labelledby="hero-h1">

  <!-- Animated blobs -->
  <div class="blob blob-violet" style="width:900px;height:900px;top:-300px;left:-300px;opacity:0.7;" aria-hidden="true"></div>
  <div class="blob blob-cyan" style="width:700px;height:700px;bottom:-200px;right:-200px;opacity:0.6;" aria-hidden="true"></div>
  <div class="blob blob-indigo" style="width:500px;height:500px;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0.4;" aria-hidden="true"></div>

  <!-- Grid -->
  <div class="bg-grid" style="position:absolute;inset:0;z-index:0;pointer-events:none;" aria-hidden="true"></div>

  <div class="container-z hero-grid">

    <!-- Left: Copy -->
    <div class="hero-copy" style="position:relative;z-index:2;">

      <!-- Live badge -->
      <div class="hero-badge reveal" data-delay="0">
        <span style="width:7px;height:7px;background:var(--emerald);border-radius:50%;display:inline-block;" class="pulse"></span>
        Salem, Tamil Nadu, India
      </div>

      <!-- Giant type -->
      <h1 id="hero-h1" class="hero-title">
        <span class="ht-line reveal" data-delay="0.06"><span class="ht-ghost">We Build</span></span>
        <span class="ht-line reveal" data-delay="0.13"><span class="ht-solid">Digital</span><span class="ht-accent">.</span></span>
        <span class="ht-line reveal" data-delay="0.20"><span class="ht-outline">Solutions</span></span>
        <span class="ht-line reveal" data-delay="0.27"><span class="ht-ghost">For Real</span></span>
        <span class="ht-line reveal" data-delay="0.34"><span class="ht-gradient">Growth.</span></span>
      </h1>

      <p class="hero-sub reveal" data-delay="0.42">
        Simple. Smart. Effective. — We are the premier <strong>Website Development Company in Salem</strong>. 
        We build fast, responsive sites, mobile apps, custom software, and run data-driven SEO & Meta Ads campaigns to skyrocket your business.
      </p>

      <div class="hero-ctas reveal" data-delay="0.50">
        <a href="/contact" class="btn-primary" id="hero-cta">
          Start a Project
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>
        <a href="#services" class="btn-secondary" id="hero-svc">Explore Services</a>
      </div>

      <!-- Trust -->
      <div class="hero-trust reveal" data-delay="0.58">
        {['Web Development Salem', 'Software Development', 'Digital Marketing'].map(t => (
          <span class="trust-pill">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {t}
          </span>
        ))}
      </div>
    </div>

    <!-- Right: Visual -->
    <div class="hero-visual reveal-right" data-delay="0.15" style="position:relative;z-index:2;">
      <div class="hero-lottie-wrapper">
        <dotlottie-player
          src="/PC Coding and Dislay app Mobile.lottie"
          background="transparent"
          speed="1"
          style="width: 100%; height: auto;"
          loop
          autoplay
        ></dotlottie-player>
      </div>

      <!-- Badge 1 -->
      <div class="float-badge float-badge-a" style="bottom:-24px;left:-28px;" aria-hidden="true">
        <div class="badge-icon" style="background:rgba(16,185,129,0.12);border:1px solid rgba(16,185,129,0.2);">🚀</div>
        <div>
          <div class="badge-title">Local SEO Salem</div>
          <div class="badge-sub">Rank #1 Google</div>
        </div>
      </div>

      <!-- Badge 2 -->
      <div class="float-badge float-badge-b" style="top:-20px;right:-24px;" aria-hidden="true">
        <div class="badge-icon" style="background:var(--v-dim);border:1px solid var(--v-border);">📈</div>
        <div>
          <div class="badge-title">HMS Software</div>
          <div class="badge-sub">Hospital Automation</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll -->
  <div class="hero-scroll" aria-hidden="true">
    <div class="scroll-cue">
      <span class="scroll-cue-label">Scroll</span>
      <div class="scroll-cue-track"><div class="scroll-cue-runner"></div></div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════
     MARQUEE
     ════════════════════════════════ -->
<div class="marquee-belt" aria-hidden="true">
  <div class="marquee-wrapper">
    <div class="marquee-track">
      {Array(2).fill(null).map(() => (
        <>
          <span class="marquee-item">Website Development Salem <span class="marquee-dot">◆</span></span>
          <span class="marquee-item">Mobile App Development <span class="marquee-dot">◆</span></span>
          <span class="marquee-item">Custom Software Company <span class="marquee-dot">◆</span></span>
          <span class="marquee-item">HMS Software Tamil Nadu <span class="marquee-dot">◆</span></span>
          <span class="marquee-item">SEO Services in Salem <span class="marquee-dot">◆</span></span>
          <span class="marquee-item">Meta Ads Specialist <span class="marquee-dot">◆</span></span>
          <span class="marquee-item">Business Automation <span class="marquee-dot">◆</span></span>
        </>
      ))}
    </div>
  </div>
</div>

<!-- ════════════════════════════════
     STATS
     ════════════════════════════════ -->
<section class="stats-section" aria-label="Key metrics">
  <div class="container-z">
    <div class="stats-grid">
      <div class="stat-block reveal">
        <span class="stat-xl" style="background:var(--gradient-text);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;" data-counter="120" data-suffix="+">120+</span>
        <span class="stat-label-sm">Projects Delivered</span>
        <div class="stat-rule" style="background:var(--gradient);"></div>
      </div>
      <div class="stat-block reveal" data-delay="0.08">
        <span class="stat-xl" style="color:var(--c4);" data-counter="10">10</span>
        <span class="stat-label-sm">Core Services</span>
        <div class="stat-rule" style="background:var(--c3);"></div>
      </div>
      <div class="stat-block reveal" data-delay="0.16">
        <span class="stat-xl" style="color:var(--v4);" data-counter="340" data-suffix="%">340%</span>
        <span class="stat-label-sm">Avg Visibility Growth</span>
        <div class="stat-rule" style="background:var(--v3);"></div>
      </div>
      <div class="stat-block reveal" data-delay="0.24">
        <span class="stat-xl" style="color:var(--emerald);" data-counter="99" data-suffix="%">99%</span>
        <span class="stat-label-sm">Client Satisfaction</span>
        <div class="stat-rule" style="background:var(--emerald);"></div>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════
     SERVICES
     ════════════════════════════════ -->
<section class="section-pad" id="services" aria-labelledby="svc-heading">
  <div class="container-z">

    <div class="svc-hdr">
      <div>
        <p class="label reveal">What We Do</p>
        <h2 id="svc-heading" class="reveal" style="font-size:var(--h2);font-weight:800;letter-spacing:-0.04em;max-width:20ch;margin-top:1rem;">
          Everything You Need to <span class="text-gradient">Scale Your Business</span>
        </h2>
      </div>
      <a href="/services" class="btn-ghost reveal" id="svc-all-link" aria-label="View all services">
        All Services Details →
      </a>
    </div>

    <div class="svc-accordion reveal">
      {services.map(s => (
        <div class="svc-item" id={`svc-${s.id}`} tabindex="0" role="button" aria-expanded="false">
          <div class="svc-row-trigger">
            <span class="svc-num-big">{s.num}</span>
            <span class="svc-name-big">{s.title}</span>
            <span class="svc-arrow-icon" aria-hidden="true">+</span>
          </div>
          <div class="svc-detail" aria-hidden="true">
            <div class="svc-detail-inner">
              <div class="svc-detail-content">
                <div style="grid-column: 1 / -1;">
                  <p class="svc-detail-desc">{s.desc}</p>
                  <div class="svc-tags-wrap" style="margin-top: 1rem; margin-bottom: 1.5rem;">
                    {s.tags.map(t => <span class="tech-tag">{t}</span>)}
                  </div>
                  <a href={`/services#${s.id}`} class="svc-cta" id={`svc-cta-${s.id}`}>
                    Explore Service <span aria-hidden="true">→</span>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════
     LOCAL SEO CONTENT SECTION (1000+ WORDS REQUIREMENT)
     ════════════════════════════════ -->
<section class="why-section local-seo-section" aria-labelledby="seo-deepdive-heading">
  <div class="blob blob-violet" style="width:700px;height:700px;top:20%;left:-200px;opacity:0.3;" aria-hidden="true"></div>
  <div class="blob blob-cyan" style="width:600px;height:600px;bottom:10%;right:-150px;opacity:0.25;" aria-hidden="true"></div>
  
  <div class="container-z" style="position:relative;z-index:1;">
    <div class="stagger-group" style="margin-bottom: 4rem;">
      <p class="label stagger-child">Local Growth Partner</p>
      <h2 id="seo-deepdive-heading" class="stagger-child" style="font-size:var(--h2);font-weight:800;letter-spacing:-0.04em;margin-top:1rem;">
        Top-Tier <span class="text-gradient">Website Development Company in Salem</span>
      </h2>
    </div>

    <div class="seo-content-grid">
      <div class="reveal-left seo-text-block">
        <h3>Empowering Salem Businesses with Responsive Website Design</h3>
        <p>
          In the digital era, having a professional, fast, and responsive website is the cornerstone of any successful enterprise. Zentrix Technology operates as a leading <strong>web development company in Salem</strong>, crafting customized digital architectures that reflect your brand's unique character. By using cutting-edge technologies like React, Next.js, and Astro, we deliver sites that load in milliseconds, optimizing your Core Web Vitals to satisfy both users and Google's search algorithms.
        </p>
        <p>
          A responsive design ensures that whether your customers in Salem, Yercaud, Meyyanur, or globally access your site on a mobile device, tablet, or desktop, they experience seamless navigation. As an experienced <strong>website development Salem</strong> provider, we blend premium design aesthetics with performance, guaranteeing lower bounce rates and increased customer engagement.
        </p>

        <h3>Bespoke Software Development & Mobile App Solutions</h3>
        <p>
          Beyond simple websites, we build systems that drive productivity. As a seasoned <strong>software company in Salem</strong>, Zentrix Technology designs custom CRM, ERP, and inventory tools built to automate complex workflows. Whether you need a mobile application designed for both iOS and Android (via Flutter or React Native) or tailored desktop software, our expert team maps your goals to clean, scalable code.
        </p>
        <p>
          Our <strong>app development Salem</strong> services focus on creating intuitive user interfaces (UI) and positive user experiences (UX). We handle the entire lifecycle, from wireframing and prototyping to final deployment on the Apple App Store and Google Play Store, ensuring your local business gains maximum mobile reach.
        </p>
      </div>

      <div class="reveal-right seo-text-block">
        <h3>Hospital Management Software (HMS) in Tamil Nadu</h3>
        <p>
          Healthcare institutions require robust, reliable, and secure automation systems to maintain high patient care standards. Zentrix Technology provides state-of-the-art <strong>hospital management software in Tamil Nadu</strong>, offering clinics, multi-specialty hospitals, and diagnostic labs a unified platform to manage operations. 
        </p>
        <p>
          Our clinic management software streamlines workflows including outpatient (OPD) and inpatient (IPD) billing, doctor schedules, lab test tracking, pharmacy stock management, and electronic medical records (EMR) management. We ensure compliance, data privacy, and extreme reliability so that healthcare centers in Salem and Tamil Nadu can eliminate paperwork and automate patient notifications seamlessly.
        </p>

        <h3>Rank Higher with Our Digital Marketing & SEO Company in Salem</h3>
        <p>
          Having a beautiful website is only half the battle; driving qualified traffic is what generates revenue. That is where our integrated marketing solutions come in. Zentrix Technology is a top-rated <strong>SEO company in Salem</strong>, implementing both local and global SEO frameworks to put your business in front of active searchers. From keyword audits and technical schema markup to high-quality link building, we ensure your site dominates Google results.
        </p>
        <p>
          To complement organic growth, our <strong>Meta Ads service in Salem</strong> executes high-converting campaigns on Facebook and Instagram. By setting up granular retargeting funnels, designing custom creatives, and tracking conversions, we maximize your Return on Ad Spend (ROAS). Partner with our <strong>digital marketing Salem</strong> team to acquire quality leads and establish industry authority.
        </p>
      </div>
    </div>

    <!-- Lead Generation CTA Panel -->
    <div class="lead-gen-panel card glass-glow reveal-scale" style="margin-top: 5rem;">
      <div class="lg-panel-content">
        <h3 style="font-size: var(--h3); font-weight: 800; margin-bottom: 1rem;">Let's Discuss Your Growth Strategy</h3>
        <p style="color: var(--t2); max-width: 600px; margin-bottom: 2rem; font-size: 0.95rem;">
          Ready to scale your business with the best software development, web design, and digital marketing services in Salem? Request a consultation or demo today.
        </p>
        <div class="lg-btns-grid">
          <a href="/contact?ref=consultation" class="btn-primary">
            Get Free Consultation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </a>
          <a href="/contact?ref=quote" class="btn-secondary">Request a Quote</a>
          <a href="/contact?ref=demo" class="btn-secondary">Book a Demo</a>
          <a href="tel:+916380957425" class="btn-secondary">📞 Call +91 63809 57425</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════
     WHY ZENTRIX (Original structure optimized with local targets)
     ════════════════════════════════ -->
<section class="why-section" aria-labelledby="why-heading">
  <div class="blob blob-violet" style="width:600px;height:600px;top:0;left:-200px;opacity:0.4;" aria-hidden="true"></div>
  <div class="blob blob-cyan" style="width:500px;height:500px;bottom:0;right:-150px;opacity:0.3;" aria-hidden="true"></div>
  
  <div class="container-z" style="position:relative;z-index:1;">
    <div class="why-head stagger-group">
      <p class="label stagger-child">Why Zentrix</p>
      <h2 id="why-heading" class="stagger-child" style="font-size:var(--h2);font-weight:800;letter-spacing:-0.04em;margin-top:1rem;max-width:20ch;">
        Data-Driven Success for <span class="text-gradient">Modern Brands</span>
      </h2>
    </div>

    {whys.map((w, i) => (
      <div class={`why-row ${i % 2 === 1 ? 'reverse' : ''}`}>
        <!-- Text -->
        <div class={i % 2 === 0 ? 'reveal-left' : 'reveal-right'}>
          <p class="why-num-label-tag">{w.num}</p>
          <h3 class="why-title">{w.title}</h3>
          <p class="why-desc">{w.desc}</p>
          <div class="why-stat-chip">
            <span class="why-stat-num">{w.stat}</span>
            <span class="why-stat-label">{w.statLabel}</span>
          </div>
          <a href="/contact" class="btn-ghost" id={`why-cta-${w.num}`}>
            Start Growing <span aria-hidden="true">→</span>
          </a>
        </div>

        <!-- Visual -->
        <div class={`why-icon-box ${i % 2 === 0 ? 'reveal-right' : 'reveal-left'}`}>
          <div class="blob blob-violet" style="width:250px;height:250px;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0.25;" aria-hidden="true"></div>
          <span class="why-icon-huge" role="img" aria-label={w.title}>{w.icon}</span>
          <span class="why-num-label">{w.num} / 03</span>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- ════════════════════════════════
     FAQ SECTION WITH FAQ SCHEMA
     ════════════════════════════════ -->
<section class="section-pad faq-section" id="faq" aria-labelledby="faq-heading">
  <div class="container-z">
    <div class="faq-head stagger-group" style="text-align: center; margin-bottom: 4rem;">
      <p class="label stagger-child" style="justify-content: center;">Got Questions?</p>
      <h2 id="faq-heading" class="stagger-child" style="font-size:var(--h2);font-weight:800;letter-spacing:-0.04em;margin-top:1rem;">
        Frequently Asked <span class="text-gradient">Questions</span>
      </h2>
      <p class="stagger-child" style="color: var(--t2); max-width: 500px; margin: 1rem auto 0; font-size: 0.95rem;">
        Learn more about our web development, custom software solutions, and marketing strategies.
      </p>
    </div>

    <div class="faq-accordion reveal">
      {faqs.map((f, idx) => (
        <div class="faq-item card" tabindex="0" role="button" aria-expanded="false" style="margin-bottom: 1rem; cursor: pointer;">
          <div class="faq-trigger" style="display: flex; justify-content: space-between; align-items: center; padding: 1.5rem 1rem;">
            <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--t1); margin: 0; text-align: left; padding-right: 1.5rem;">{f.q}</h3>
            <span class="faq-icon" style="color: var(--v4); font-size: 1.25rem; font-weight: 800;">+</span>
          </div>
          <div class="faq-answer-wrapper" style="max-height: 0; overflow: hidden; transition: max-height 350ms var(--expo); padding: 0 1rem;">
            <p style="color: var(--t2); font-size: 0.9375rem; line-height: 1.7; padding-bottom: 1.5rem;">{f.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════════════════
     CTA (Lead-Gen Optimized)
     ════════════════════════════════ -->
<section class="cta-section" aria-labelledby="cta-heading">
  <div class="blob blob-violet" style="width:700px;height:700px;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0.5;" aria-hidden="true"></div>
  <div class="cta-glow" aria-hidden="true"></div>
  <div class="container-z cta-inner">
    <p class="label reveal" style="justify-content:center;margin-bottom:1.5rem;">Next Step</p>
    <h2 id="cta-heading" class="reveal cta-title">
      Ready to Drive<br/>
      <span class="text-gradient">Real Growth?</span>
    </h2>
