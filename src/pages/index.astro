---
import Layout from '../layouts/Layout.astro';
import { ArrowRight, ChevronRight, Layers, Smartphone, Megaphone, Zap, Shield, Rocket } from 'lucide-react';
---

<Layout title="Home">
  
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Topographic Parallax Background -->
    <div class="absolute inset-0 z-0 topographic-lines opacity-10 hero-parallax"></div>
    <div class="absolute inset-0 z-0 technical-grid opacity-10"></div>
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 z-1 bg-gradient-to-b from-black/60 via-transparent to-black/60"></div>

    <div class="container mx-auto px-6 relative z-10 text-center flex flex-col items-center">
      <div class="hero-reveal-container mb-12 overflow-hidden">
         <div class="hero-tag text-[9px] font-mono tracking-[0.6em] text-white uppercase flex items-center gap-4 reveal-up">
            <span class="w-12 h-[1px] bg-white"></span>
            Established MMXVII
            <span class="w-12 h-[1px] bg-white"></span>
         </div>
      </div>
      
      <h1 class="hero-title text-7xl md:text-9xl lg:text-[140px] font-serif italic text-white max-w-6xl mb-12 leading-[0.85] reveal-up">
        The Art of <br/> <span class="not-italic text-white">Digital</span> <br/> Wilderness.
      </h1>
      
      <p class="hero-desc text-lg md:text-xl text-white max-w-2xl mb-16 leading-relaxed font-mono tracking-tight reveal-up">
        Bridging high-velocity engineering with the raw essence of human-centric design. Zentrix builds platforms for the era of dominance.
      </p>
      
      <div class="hero-actions flex flex-col sm:flex-row items-center gap-8 reveal-up">
        <a href="/contact" class="px-12 py-6 bg-white text-black rounded-full text-[10px] font-black tracking-[0.3em] uppercase hover:bg-white/90 transition-all duration-500 flex items-center gap-4 group">
          Init Discovery
          <ArrowRight className="w-4 h-4 group-hover:translate-x-1 transition-transform" />
        </a>
        <a href="/works" class="px-12 py-6 border border-white text-white rounded-full text-[10px] font-black tracking-[0.3em] uppercase hover:bg-white/5 transition-all duration-500">
          Our Archives
        </a>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4 opacity-50">
       <span class="text-[8px] font-mono tracking-[0.5em] uppercase text-white">Explore</span>
       <div class="w-[1px] h-16 bg-gradient-to-b from-white to-transparent scroll-line"></div>
    </div>
  </section>

  <!-- Mission Section (Sticky Effect) -->
  <section class="relative py-60 overflow-hidden mission-section">
    <div class="container mx-auto px-6">
      <div class="flex flex-col lg:flex-row gap-20 items-start">
        <div class="lg:w-1/2 sticky top-40">
          <span class="text-[10px] font-mono tracking-[0.5em] text-white uppercase mb-8 block">Our Ethos</span>
          <h2 class="text-6xl md:text-8xl font-serif text-white leading-none mb-12">
            Engineering <br/><span class="italic text-white">Purity</span> <br/>In Every Line.
          </h2>
        </div>
        <div class="lg:w-1/2 pt-40 lg:pt-80">
          <div class="space-y-40">
            <div class="reveal-on-scroll">
              <h3 class="text-3xl font-serif text-white mb-6 italic">Uncompromising Performance</h3>
              <p class="text-xl text-white leading-relaxed font-mono">
                We don't just build websites. We craft digital ecosystems that breathe with your brand. Every millisecond of latency is a barrier we dismantle with surgical precision.
              </p>
            </div>
            <div class="reveal-on-scroll">
              <h3 class="text-3xl font-serif text-white mb-6 italic">Visual Sovereignty</h3>
              <p class="text-xl text-white leading-relaxed font-mono">
                Design is the skin of technology. We ensure that skin is flawless, premium, and capable of commanding attention in a world of digital noise.
              </p>
            </div>
            <div class="reveal-on-scroll">
              <h3 class="text-3xl font-serif text-white mb-6 italic">Scalable Resilience</h3>
              <p class="text-xl text-white leading-relaxed font-mono">
                Our architectures are built to endure. From day one to one million users, Zentrix platforms scale vertically and horizontally without friction.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Showcase Section (Grid) -->
  <section class="py-40">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-1 px-1 bg-white/5 border border-white/10 rounded-[3rem] overflow-hidden">
        <div class="p-16 aspect-square flex flex-col justify-between bg-black/40 hover:bg-black/60 transition-colors duration-700 reveal-on-scroll">
          <Layers className="w-12 h-12 text-white" />
          <div>
            <h4 class="text-2xl font-serif text-white mb-4">Web Core</h4>
            <p class="text-xs font-mono text-white uppercase tracking-widest">Next.js / Astro / Rust</p>
          </div>
        </div>
        <div class="p-16 aspect-square flex flex-col justify-between bg-black/40 hover:bg-black/60 transition-colors duration-700 reveal-on-scroll">
          <Smartphone className="w-12 h-12 text-white" />
          <div>
            <h4 class="text-2xl font-serif text-white mb-4">Mobile Hub</h4>
            <p class="text-xs font-mono text-white uppercase tracking-widest">React Native / Swift</p>
          </div>
        </div>
        <div class="p-16 aspect-square flex flex-col justify-between bg-black/40 hover:bg-black/60 transition-colors duration-700 reveal-on-scroll">
          <Zap className="w-12 h-12 text-white" />
          <div>
            <h4 class="text-2xl font-serif text-white mb-4">Speed Engine</h4>
            <p class="text-xs font-mono text-white uppercase tracking-widest">Global Edge Edge / CDN</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-60 text-center relative overflow-hidden">
    <div class="absolute inset-0 topographic-lines opacity-10 cta-parallax"></div>
    <div class="container mx-auto px-6 relative z-10">
      <h2 class="text-7xl md:text-[160px] font-serif italic text-white leading-none mb-20 reveal-up">
        Ready for <br/> <span class="not-italic text-white">Ascension?</span>
      </h2>
      <a href="/contact" class="inline-block px-16 py-8 bg-white text-black rounded-full text-[12px] font-black tracking-[0.4em] uppercase hover:scale-105 transition-transform duration-700">
        Contact the Collective
      </a>
    </div>
  </section>

</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    // Hero Entrance
    const heroTl = gsap.timeline({ delay: 1.5 });
    
    heroTl.from('.reveal-up', {
      y: 100,
      opacity: 0,
      duration: 1.5,
      stagger: 0.2,
      ease: 'expo.out'
    });

    // Parallax Backgrounds
    gsap.to('.hero-parallax', {
      yPercent: 30,
      ease: 'none',
      scrollTrigger: {
        trigger: 'section',
        start: 'top top',
        end: 'bottom top',
        scrub: true
      }
    });

    gsap.to('.cta-parallax', {
      yPercent: -20,
      ease: 'none',
      scrollTrigger: {
        trigger: 'section',
        start: 'top bottom',
        end: 'bottom top',
        scrub: true
      }
    });

    // Scroll Indicator Animation
    gsap.to('.scroll-line', {
      scaleY: 0,
      transformOrigin: 'bottom',
      repeat: -1,
      duration: 1.5,
      ease: 'power2.inOut'
    });

    // Text Reveal Animations
    const reveals = document.querySelectorAll('.reveal-on-scroll');
    reveals.forEach(el => {
      gsap.from(el, {
        y: 60,
        opacity: 0,
        duration: 1.2,
        ease: 'expo.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          toggleActions: 'play none none none'
        }
      });
    });
  });

  // Handle Barba events
  document.addEventListener('barba_after', () => {
     // Re-init ScrollTrigger if needed
     ScrollTrigger.refresh();
  });
</script>
